<!doctype html>
<html lang="ko">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>웹하드 공유</title>
    <link rel="stylesheet" href="/assets/admin/css/admin.css">
    <link rel="stylesheet" href="/assets/admin/css/all.css">
</head>
<body class="bg-light">
<div class="container-fluid py-4">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h1 class="h4 mb-0">웹하드 공유 ({{ total_size_human }})</h1>
        {% if parent_path %}
            <a href="/share/webhard/{{ token }}{% if parent_path %}?path={{ parent_path|url_encode }}{% endif %}" class="btn btn-sm btn-outline-secondary">상위 폴더</a>
        {% endif %}
    </div>

    {% if flash %}
        <div class="alert alert-{{ flash.error ? 'danger' : 'success' }}">{{ flash.message }}</div>
    {% endif %}

    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            {% for crumb in breadcrumbs %}
                <li class="breadcrumb-item {{ loop.last ? 'active' : '' }}">
                    {% if loop.last %}
                        {{ crumb.label }}
                    {% else %}
                        <a href="/share/webhard/{{ token }}{% if crumb.path %}?path={{ crumb.path|url_encode }}{% endif %}">{{ crumb.label }}</a>
                    {% endif %}
                </li>
            {% endfor %}
        </ol>
    </nav>

    {% if share.can_upload %}
        <div class="card mb-4">
            <div class="card-header">업로드</div>
            <div class="card-body">
                <form action="/share/webhard/{{ token }}/upload" method="POST" enctype="multipart/form-data" class="form-inline mb-3 single-upload-form" data-chunk-url="/share/webhard/{{ token }}/upload-chunk">
                    <input type="hidden" name="path" value="{{ current_path }}">
                    <input type="file" name="file" id="single-file-input" class="form-control-file d-none" required>
                    <button type="button" id="single-file-picker-btn" class="btn btn-outline-success mr-2 mb-2">파일 선택</button>
                    <button type="submit" class="btn btn-success mb-2">업로드</button>
                </form>
                <form id="folder-upload-form" class="form-inline">
                    <input type="hidden" name="path" value="{{ current_path }}">
                    <input type="file" name="files[]" id="folder-upload-input" class="form-control-file mr-2 mb-2" webkitdirectory directory multiple>
                    <button type="button" id="folder-picker-btn" class="btn btn-outline-info mr-2 mb-2" style="display: none;">폴더 선택</button>
                    <button type="submit" class="btn btn-info mb-2">폴더 통째로 업로드</button>
                </form>
            </div>
        </div>
    {% endif %}

    <div class="card mb-4">
        <div class="card-header">폴더 ({{ folder_count }}개)</div>
        <div class="table-responsive">
            <table class="table mb-0">
                <thead class="thead-light">
                    <tr>
                        <th>이름</th>
                        <th>수정일</th>
                        {% if share.can_download %}<th style="width: 120px;">다운로드</th>{% endif %}
                    </tr>
                </thead>
                <tbody>
                    {% for folder in folders %}
                        <tr>
                            <td><a href="{{ folder.url }}"><i class="fas fa-folder-open text-warning mr-1"></i>{{ folder.name }}</a></td>
                            <td>{{ folder.modified }}</td>
                            {% if share.can_download %}<td><a href="{{ folder.download_url }}" class="btn btn-sm btn-outline-primary">ZIP</a></td>{% endif %}
                        </tr>
                    {% else %}
                        <tr><td colspan="{{ share.can_download ? 3 : 2 }}" class="text-center text-muted p-4">폴더가 없습니다.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="card mb-5">
        <div class="card-header">파일 ({{ file_count }}개)</div>
        <div class="table-responsive">
            <table class="table mb-0">
                <thead class="thead-light">
                    <tr>
                        <th>이름</th>
                        <th style="width: 90px;">미리보기</th>
                        <th>크기</th>
                        <th>수정일</th>
                        {% if share.can_download %}<th style="width: 120px;">다운로드</th>{% endif %}
                    </tr>
                </thead>
                <tbody>
                    {% for file in files %}
                        <tr>
                            <td><i class="fas {{ file.is_image ? 'fa-file-image' : 'fa-file-alt' }} text-secondary mr-1"></i>{{ file.name }}</td>
                            <td>
                                {% if file.is_image %}
                                    <button type="button" class="btn btn-link p-0 preview-btn" data-src="{{ file.preview_url }}" data-download="{{ file.url }}" data-name="{{ file.name }}">
                                        <img src="{{ file.preview_url }}" alt="{{ file.name }}" class="img-thumbnail" style="width: 56px; height: 56px; object-fit: cover;">
                                    </button>
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            </td>
                            <td>{{ (file.size / 1024)|number_format(1, '.', ',') }} KB</td>
                            <td>{{ file.modified }}</td>
                            {% if share.can_download %}<td><a href="{{ file.url }}" class="btn btn-sm btn-outline-primary">다운로드</a></td>{% endif %}
                        </tr>
                    {% else %}
                        <tr><td colspan="{{ share.can_download ? 5 : 4 }}" class="text-center text-muted p-4">파일이 없습니다.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="image-preview-modal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="image-preview-title">이미지 미리보기</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="닫기"><span aria-hidden="true">&times;</span></button>
            </div>
            <div class="modal-body text-center bg-light">
                <img id="image-preview-img" src="" alt="" class="img-fluid" style="max-height: 75vh;">
            </div>
            <div class="modal-footer">
                {% if share.can_download %}<a href="#" id="image-preview-download" class="btn btn-primary">다운로드</a>{% endif %}
                <button type="button" class="btn btn-secondary" data-dismiss="modal">닫기</button>
            </div>
        </div>
    </div>
</div>

<script src="/assets/js/jquery.min.js"></script>
<script src="/assets/js/bootstrap.bundle.min.js"></script>
<script>
(function() {
    var singleFileInput = document.getElementById('single-file-input');
    var singleFilePickerBtn = document.getElementById('single-file-picker-btn');
    var singleUploadForm = document.querySelector('.single-upload-form');
    if (singleFileInput && singleFilePickerBtn) {
        singleFilePickerBtn.addEventListener('click', function() { singleFileInput.click(); });
    }
    if (singleUploadForm && singleFileInput) {
        singleUploadForm.addEventListener('submit', function(e) {
            var file = singleFileInput.files && singleFileInput.files[0] ? singleFileInput.files[0] : null;
            if (!file) return;
            e.preventDefault();

            var submitBtn = singleUploadForm.querySelector('button[type="submit"]');
            submitBtn.disabled = true;
            submitBtn.textContent = '업로드 중...';

            uploadSingleFileInChunks(
                singleUploadForm.dataset.chunkUrl,
                singleUploadForm.querySelector('input[name="path"]').value || '',
                file,
                file.name,
                function(done, total) {
                    submitBtn.textContent = '업로드 중... ' + done + '/' + total;
                }
            ).then(function() {
                alert('파일 업로드가 완료되었습니다.');
                window.location.reload();
            }).catch(function() {
                alert('파일 업로드에 실패했습니다.');
            }).finally(function() {
                submitBtn.disabled = false;
                submitBtn.textContent = '업로드';
            });
        });
    }

    document.querySelectorAll('.preview-btn').forEach(function(button) {
        button.addEventListener('click', function() {
            document.getElementById('image-preview-img').src = button.dataset.src || '';
            document.getElementById('image-preview-title').textContent = button.dataset.name || '이미지 미리보기';
            var download = document.getElementById('image-preview-download');
            if (download) {
                download.href = button.dataset.download || '#';
            }
            if (window.jQuery) {
                window.jQuery('#image-preview-modal').modal('show');
            }
        });
    });

    var folderForm = document.getElementById('folder-upload-form');
    var folderInput = document.getElementById('folder-upload-input');
    var folderPickerBtn = document.getElementById('folder-picker-btn');
    var selectedFolderHandle = null;
    if (!folderForm || !folderInput) {
        return;
    }

    if (folderPickerBtn && window.showDirectoryPicker) {
        folderPickerBtn.style.display = '';
        folderInput.style.display = 'none';
        folderPickerBtn.addEventListener('click', function() {
            window.showDirectoryPicker().then(function(handle) {
                selectedFolderHandle = handle;
                folderPickerBtn.textContent = handle.name;
            });
        });
    }

    folderForm.addEventListener('submit', function(e) {
        e.preventDefault();
        if (!selectedFolderHandle && (!folderInput.files || folderInput.files.length === 0)) {
            alert('업로드할 폴더를 선택하세요.');
            return;
        }

        var submitBtn = folderForm.querySelector('button[type="submit"]');
        submitBtn.disabled = true;
        submitBtn.textContent = '업로드 중...';
        var basePath = folderForm.querySelector('input[name="path"]').value || '';
        var collect = selectedFolderHandle ? collectFolderHandleEntries(selectedFolderHandle, selectedFolderHandle.name) : Promise.resolve(collectInputFolderEntries(folderInput.files));

        collect.then(function(payload) {
            return uploadFolderBatches(basePath, payload.files, payload.directories, function(done, total) {
                submitBtn.textContent = '업로드 중... ' + done + '/' + total;
            });
        }).then(function(result) {
            alert(result.message);
            window.location.reload();
        }).catch(function() {
            alert('업로드에 실패했습니다.');
        }).finally(function() {
            submitBtn.disabled = false;
            submitBtn.textContent = '폴더 통째로 업로드';
        });
    });

    function collectInputFolderEntries(fileList) {
        var files = [];
        var directories = {};
        Array.from(fileList).forEach(function(file) {
            var relativePath = file.webkitRelativePath || file.name;
            files.push({ file: file, path: relativePath });
            var parts = relativePath.split('/');
            parts.pop();
            var current = '';
            parts.forEach(function(part) {
                current = current ? current + '/' + part : part;
                directories[current] = true;
            });
        });
        return { files: files, directories: Object.keys(directories) };
    }

    async function collectFolderHandleEntries(directoryHandle, relativePath) {
        var payload = { files: [], directories: [relativePath] };
        await appendFolderHandleEntries(payload, directoryHandle, relativePath);
        return payload;
    }

    async function appendFolderHandleEntries(payload, directoryHandle, relativePath) {
        for await (var entry of directoryHandle.values()) {
            var childPath = relativePath + '/' + entry.name;
            if (entry.kind === 'directory') {
                payload.directories.push(childPath);
                await appendFolderHandleEntries(payload, entry, childPath);
            } else if (entry.kind === 'file') {
                payload.files.push({ file: await entry.getFile(), path: childPath });
            }
        }
    }

    function uploadFolderBatches(basePath, files, directories, onProgress) {
        var fileBatches = makeFileBatches(files, 15, 25 * 1024 * 1024);
        var totalSteps = Math.ceil(directories.length / 200) + fileBatches.length;
        var doneSteps = 0;
        var uploadedFiles = 0;
        var createdDirs = 0;
        var chain = Promise.resolve();

        for (var d = 0; d < directories.length; d += 200) {
            (function(batch) {
                chain = chain.then(function() {
                    return uploadFolderBatch(basePath, [], batch).then(function(json) {
                        if (!json.success) throw new Error(json.message || 'failed');
                        createdDirs += Number(json.created_dirs || 0);
                        onProgress(++doneSteps, totalSteps);
                    });
                });
            })(directories.slice(d, d + 200));
        }

        fileBatches.forEach(function(batch) {
            chain = chain.then(function() {
                return uploadFolderFileBatch(basePath, batch).then(function(count) {
                    uploadedFiles += count;
                    onProgress(++doneSteps, totalSteps);
                });
            });
        });

        return chain.then(function() {
            return { message: uploadedFiles + '개 파일 업로드, ' + createdDirs + '개 폴더 생성 완료' };
        });
    }

    function makeFileBatches(files, maxCount, maxBytes) {
        var batches = [];
        var current = [];
        var currentBytes = 0;
        files.forEach(function(item) {
            var size = item.file && item.file.size ? item.file.size : 0;
            if (current.length > 0 && (current.length >= maxCount || currentBytes + size > maxBytes)) {
                batches.push(current);
                current = [];
                currentBytes = 0;
            }
            current.push(item);
            currentBytes += size;
        });
        if (current.length > 0) batches.push(current);
        return batches;
    }

    function uploadFolderBatch(basePath, files, directories) {
        var formData = new FormData();
        formData.append('path', basePath);
        directories.forEach(function(directory) { formData.append('directories[]', directory); });
        files.forEach(function(item) {
            formData.append('files[]', item.file);
            formData.append('paths[]', item.path);
        });
        return fetch('/share/webhard/{{ token }}/upload-folder', { method: 'POST', body: formData }).then(function(res) { return res.json(); });
    }

    function uploadFolderFileBatch(basePath, files) {
        var chunkThreshold = 25 * 1024 * 1024;
        var normalFiles = files.filter(function(item) { return item.file.size <= chunkThreshold; });
        var largeFiles = files.filter(function(item) { return item.file.size > chunkThreshold; });
        var uploaded = 0;
        var chain = Promise.resolve();

        if (normalFiles.length > 0) {
            chain = chain.then(function() {
                return uploadFolderBatch(basePath, normalFiles, []).then(function(json) {
                    if (!json.success) throw new Error(json.message || 'failed');
                    uploaded += Number(json.uploaded_files || 0);
                });
            });
        }

        largeFiles.forEach(function(item) {
            chain = chain.then(function() {
                return uploadSingleFileInChunks('/share/webhard/{{ token }}/upload-chunk', basePath, item.file, item.path).then(function() {
                    uploaded++;
                });
            });
        });

        return chain.then(function() {
            return uploaded;
        });
    }

    function uploadSingleFileInChunks(url, basePath, file, relativePath, onProgress) {
        var chunkSize = 20 * 1024 * 1024;
        var totalChunks = Math.max(1, Math.ceil(file.size / chunkSize));
        var uploadId = Date.now().toString(36) + '_' + Math.random().toString(36).slice(2);
        var chain = Promise.resolve();

        for (var i = 0; i < totalChunks; i++) {
            (function(index) {
                chain = chain.then(function() {
                    var start = index * chunkSize;
                    var end = Math.min(start + chunkSize, file.size);
                    var formData = new FormData();
                    formData.append('path', basePath);
                    formData.append('upload_id', uploadId);
                    formData.append('file_name', file.name);
                    formData.append('relative_path', relativePath || file.name);
                    formData.append('chunk_index', index);
                    formData.append('total_chunks', totalChunks);
                    formData.append('chunk', file.slice(start, end), file.name + '.part');

                    return fetch(url, { method: 'POST', body: formData })
                        .then(function(res) { return res.json(); })
                        .then(function(json) {
                            if (!json.success) throw new Error(json.message || 'chunk failed');
                            if (onProgress) onProgress(index + 1, totalChunks);
                        });
                });
            })(i);
        }

        return chain;
    }
})();
</script>
</body>
</html>

<!-- CONTACT   // S -->
<div id="contact">
    <div class="title">
        <h3>CONTACT US</h3>
        <p>궁금한 사항이 있으신가요? 담당자가 확인 후 빠르게 회신드립니다</p>
    </div>

    <div class="formbox" data-aos="fade-up" data-aos-delay="300" data-aos-duration="1000">
        <form id="contactForm" method="post" action="/contact/submit" novalidate>
            <input type="hidden" name="contact_token" value="{{ contact_form_token|default(contact_token|default('')) }}">
            <input type="hidden" name="contact_method" value="" tabindex="-1" autocomplete="off" class="contact-honeypot" aria-hidden="true">

            <ul>
                <li class="half">
                    <p class="tit">업체명 <font>*</font></p>
                    <input type="text" placeholder="업체, 단체명을 입력해 주세요." name="company" value="" required>
                </li>
                <li class="half">
                    <p class="tit">성명 <font>*</font></p>
                    <input type="text" placeholder="성명을 입력해 주세요." name="name" value="" required>
                </li>
                <li class="half">
                    <p class="tit">연락처 <font>*</font></p>
                    <input type="text" placeholder="숫자만 입력해 주세요." name="phone" value="" inputmode="numeric" maxlength="13" autocomplete="tel" required>
                </li>
                <li class="half">
                    <p class="tit">이메일 <font>*</font></p>
                    <input type="email" placeholder="이메일을 입력해 주세요." name="email" value="" inputmode="email" required>
                </li>
                <li class="half">
                    <p class="tit">예산 <font>*</font></p>
                    <input type="text" placeholder="희망 예산을 만원 단위로 입력해 주세요." name="money" value="" inputmode="numeric" required>
                </li>
                <li class="memo">
                    <p class="tit">문의내용 <font>*</font></p>
                    <textarea name="message" placeholder="문의내용을 입력해 주세요." required></textarea>
                </li>
            </ul>

            <div class="btnbox">
                <button type="submit">
                    문의하기
                    <img src="../images/arrow_white.png" alt="">
                </button>
            </div>
            <p id="formMessage" class="form-message" aria-live="polite"></p>
        </form>
    </div>
</div>
<script src="/assets/js/contact.js"></script>
<!-- CONTACT   // E -->

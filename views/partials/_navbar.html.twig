<script>
    document.addEventListener('DOMContentLoaded', function () {
        const menu = document.getElementById('menuArea');
        const burger = document.querySelector('.burger');
        const closeButton = document.querySelector('#menuArea .btnMenu_mClose');

        function closeMenu() {
            if (menu) menu.classList.remove('on');
            const layer = document.getElementById('grayLayer');
            if (layer) layer.remove();
        }

        if (burger && menu) {
            burger.addEventListener('click', function (event) {
                event.preventDefault();
                menu.classList.add('on');
                if (!document.getElementById('grayLayer')) {
                    const layer = document.createElement('div');
                    layer.id = 'grayLayer';
                    layer.innerHTML = '<a href="#"></a>';
                    layer.addEventListener('click', function (layerEvent) {
                        layerEvent.preventDefault();
                        closeMenu();
                    });
                    document.body.appendChild(layer);
                }
            });
        }

        if (closeButton) {
            closeButton.addEventListener('click', closeMenu);
        }
    });

    window.addEventListener('scroll', function () {
        const header = document.getElementById('header');
        if (!header) return;
        header.classList.toggle('onheader', window.scrollY > 100);
    });
</script>

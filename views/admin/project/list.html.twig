{% extends 'admin/layout/base.html.twig' %}

{% block content %}
<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="h3 mb-0 text-gray-800">프로젝트 목록</h1>
        <p class="text-muted mb-0">조회 {{ projects|length }}개 / 전체 {{ summary.total }}개 프로젝트</p>
    </div>
    <div>
        <a href="/admin/project/export{% if export_query %}?{{ export_query }}{% endif %}" class="btn btn-sm btn-outline-success">CSV 다운로드</a>
        <a href="/admin/project/add" class="btn btn-sm btn-primary">+ 프로젝트 등록</a>
    </div>
</div>

<div class="row">
    <div class="col-xl-2 col-md-4 col-6 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body py-3">
                <div class="small text-muted">전체</div>
                <div class="h5 mb-0 font-weight-bold text-gray-800">{{ summary.total }}</div>
            </div>
        </div>
    </div>
    <div class="col-xl-2 col-md-4 col-6 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body py-3">
                <div class="small text-muted">진행중</div>
                <div class="h5 mb-0 font-weight-bold text-success">{{ summary.active }}</div>
            </div>
        </div>
    </div>
    <div class="col-xl-2 col-md-4 col-6 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body py-3">
                <div class="small text-muted">보류</div>
                <div class="h5 mb-0 font-weight-bold text-warning">{{ summary.hold }}</div>
            </div>
        </div>
    </div>
    <div class="col-xl-2 col-md-4 col-6 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body py-3">
                <div class="small text-muted">만료 항목</div>
                <div class="h5 mb-0 font-weight-bold text-danger">{{ summary.expired }}</div>
            </div>
        </div>
    </div>
    <div class="col-xl-2 col-md-4 col-6 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body py-3">
                <div class="small text-muted">임박 30일</div>
                <div class="h5 mb-0 font-weight-bold text-danger">{{ summary.due_30 }}</div>
            </div>
        </div>
    </div>
    <div class="col-xl-2 col-md-4 col-6 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body py-3">
                <div class="small text-muted">만료일 없음</div>
                <div class="h5 mb-0 font-weight-bold text-secondary">{{ summary.no_expiry }}</div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <form method="get" action="/admin/project/list" class="form-row align-items-end">
            <div class="form-group col-lg-4 col-md-6">
                <label class="small font-weight-bold">검색</label>
                <input type="search" name="q" class="form-control" value="{{ filters.q }}" placeholder="프로젝트명, 고객사, URL, 담당자">
            </div>
            <div class="form-group col-lg-2 col-md-3">
                <label class="small font-weight-bold">상태</label>
                <select name="status" class="form-control">
                    <option value="">전체</option>
                    <option value="active" {% if filters.status == 'active' %}selected{% endif %}>진행중</option>
                    <option value="hold" {% if filters.status == 'hold' %}selected{% endif %}>보류</option>
                    <option value="inactive" {% if filters.status == 'inactive' %}selected{% endif %}>종료</option>
                    <option value="expired" {% if filters.status == 'expired' %}selected{% endif %}>만료</option>
                </select>
            </div>
            <div class="form-group col-lg-2 col-md-3">
                <label class="small font-weight-bold">만료 상태</label>
                <select name="expiry" class="form-control">
                    <option value="">전체</option>
                    <option value="expired" {% if filters.expiry == 'expired' %}selected{% endif %}>이미 만료</option>
                    <option value="7" {% if filters.expiry == '7' %}selected{% endif %}>7일 이내</option>
                    <option value="30" {% if filters.expiry == '30' %}selected{% endif %}>30일 이내</option>
                    <option value="60" {% if filters.expiry == '60' %}selected{% endif %}>60일 이내</option>
                    <option value="none" {% if filters.expiry == 'none' %}selected{% endif %}>만료일 없음</option>
                </select>
            </div>
            <div class="form-group col-lg-2 col-md-4">
                <label class="small font-weight-bold">업체</label>
                <select name="company_id" class="form-control">
                    <option value="0">전체</option>
                    {% for company in companies %}
                        <option value="{{ company.id }}" {% if filters.company_id == company.id %}selected{% endif %}>{{ company.name }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="form-group col-lg-2 col-md-4">
                <label class="small font-weight-bold">담당자</label>
                <select name="manager" class="form-control">
                    <option value="">전체</option>
                    {% for manager in managers %}
                        <option value="{{ manager }}" {% if filters.manager == manager %}selected{% endif %}>{{ manager }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="form-group col-lg-2 col-md-8 d-flex">
                <button type="submit" class="btn btn-primary flex-fill mr-2">검색</button>
                <a href="/admin/project/list" class="btn btn-outline-secondary">초기화</a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="thead-light">
                    <tr>
                        <th style="width: 80px;">ID</th>
                        <th>프로젝트명</th>
                        <th style="width: 200px;">URL</th>
                        <th style="width: 140px;">URL 만료일</th>
                        <th style="width: 140px;">SSL 만료일</th>
                        <th style="width: 140px;">호스팅 만료일</th>
                        <th style="width: 140px;">유지보수 만료일</th>
                        <th style="width: 120px;">상태</th>
                        <th style="width: 180px;">관리</th>
                    </tr>
                </thead>
                <tbody>
                    {% for project in projects %}
                    {% set url_alert = project.url_expiry_days is not null and project.url_expiry_days <= 30 and project.url_expiry_days >= 0 %}
                    {% set ssl_alert = project.ssl_expiry_days is not null and project.ssl_expiry_days <= 30 and project.ssl_expiry_days >= 0 %}
                    {% set hosting_alert = project.hosting_expiry_days is not null and project.hosting_expiry_days <= 30 and project.hosting_expiry_days >= 0 %}
                    {% set maintenance_alert = project.maintenance_expiry_days is not null and project.maintenance_expiry_days <= 30 and project.maintenance_expiry_days >= 0 %}
                    {% set url_expired = project.url_expiry_days is not null and project.url_expiry_days < 0 %}
                    {% set ssl_expired = project.ssl_expiry_days is not null and project.ssl_expiry_days < 0 %}
                    {% set hosting_expired = project.hosting_expiry_days is not null and project.hosting_expiry_days < 0 %}
                    {% set maintenance_expired = project.maintenance_expiry_days is not null and project.maintenance_expiry_days < 0 %}
                    <tr>
                        <td class="text-muted">{{ project.id }}</td>
                        <td>
                            <a href="/admin/project/{{ project.id }}/view">{{ project.name }}</a>
                            {% if project.company_id and project.company_name %}
                                <div class="small"><a href="/admin/company/{{ project.company_id }}/view">{{ project.company_name }}</a></div>
                            {% elseif project.client_name %}
                                <div class="small text-muted">{{ project.client_name }}</div>
                            {% endif %}
                        </td>
                        <td class="small text-truncate" style="max-width: 220px;">
                            {% if project.site_url %}
                                <a href="{{ project.site_url }}" target="_blank" rel="noopener noreferrer">{{ project.site_url }}</a>
                            {% else %}
                                -
                            {% endif %}
                        </td>
                        <td class="small">
                            {% if project.url_expiry_date %}
                                {{ project.url_expiry_date }}
                                {% if url_alert %}<span class="expiry-dot" title="D-30 임박"></span>{% endif %}
                                {% if url_expired %}<span class="badge badge-danger ml-1">만료</span>{% endif %}
                            {% else %}
                                <span class="badge badge-secondary">미계약</span>
                            {% endif %}
                        </td>
                        <td class="small">
                            {% if project.ssl_expiry_date %}
                                {{ project.ssl_expiry_date }}
                                {% if ssl_alert %}<span class="expiry-dot" title="D-30 임박"></span>{% endif %}
                                {% if ssl_expired %}<span class="badge badge-danger ml-1">만료</span>{% endif %}
                            {% else %}
                                <span class="badge badge-secondary">미계약</span>
                            {% endif %}
                        </td>
                        <td class="small">
                            {% if project.hosting_expiry_date %}
                                {{ project.hosting_expiry_date }}
                                {% if hosting_alert %}<span class="expiry-dot" title="D-30 임박"></span>{% endif %}
                                {% if hosting_expired %}<span class="badge badge-danger ml-1">만료</span>{% endif %}
                            {% else %}
                                <span class="badge badge-secondary">미계약</span>
                            {% endif %}
                        </td>
                        <td class="small">
                            {% if project.maintenance_expiry_date %}
                                {{ project.maintenance_expiry_date }}
                                {% if maintenance_alert %}<span class="expiry-dot" title="D-30 임박"></span>{% endif %}
                                {% if maintenance_expired %}<span class="badge badge-danger ml-1">만료</span>{% endif %}
                            {% else %}
                                <span class="badge badge-secondary">미계약</span>
                            {% endif %}
                        </td>
                        <td>
                            <span class="badge badge-status badge-{{ project.status }}">{{ project.status }}</span>
                        </td>
                        <td>
                            <a href="/admin/project/{{ project.id }}/view" class="btn btn-sm btn-outline-info">보기</a>
                            <a href="/admin/project/{{ project.id }}/edit" class="btn btn-sm btn-outline-warning">수정</a>
                            <form method="post" action="/admin/project/{{ project.id }}/delete" class="d-inline" onsubmit="return confirm('삭제할까요?')">
                                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                                <button type="submit" class="btn btn-sm btn-outline-danger">삭제</button>
                            </form>
                        </td>
                    </tr>
                    {% else %}
                    <tr><td colspan="9" class="text-center text-muted p-4">조건에 맞는 프로젝트가 없습니다.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}

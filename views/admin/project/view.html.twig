{% extends 'admin/layout/base.html.twig' %}

{% block content %}
<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="h3 mb-0 text-gray-800">프로젝트 정보</h1>
        <p class="text-muted mb-0">{{ project.name }}</p>
    </div>
    <div>
        <a href="/admin/project/list" class="btn btn-sm btn-outline-secondary">목록</a>
        <a href="/admin/project/{{ project.id }}/edit" class="btn btn-sm btn-primary">수정</a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="form-group">
            <label><strong>프로젝트명</strong></label>
            <p class="form-control-plaintext">{{ project.name }}</p>
        </div>

        <div class="form-group">
            <label><strong>연결 업체</strong></label>
            <p class="form-control-plaintext">
                {% if project.company_id and project.company_name %}
                    <a href="/admin/company/{{ project.company_id }}/view">{{ project.company_name }}</a>
                    {% if project.company_manager %}<span class="small text-muted ml-2">{{ project.company_manager }}</span>{% endif %}
                {% else %}
                    -
                {% endif %}
            </p>
        </div>

        <div class="form-group">
            <label><strong>고객사/기관 메모</strong></label>
            <p class="form-control-plaintext">{{ project.client_name ?? '-' }}</p>
        </div>

        <div class="form-group">
            <label><strong>사이트 URL</strong></label>
            <p class="form-control-plaintext">
                {% if project.site_url %}
                    <a href="{{ project.site_url }}" target="_blank" rel="noopener noreferrer">{{ project.site_url }}</a>
                {% else %}
                    -
                {% endif %}
            </p>
        </div>

        <div class="form-group">
            <label><strong>프로젝트 시작일</strong></label>
            <p class="form-control-plaintext">{{ project.start_date ?? '-' }}</p>
        </div>

        <div class="form-group">
            <label><strong>URL 만료일</strong></label>
            <p class="form-control-plaintext">
                {% if project.url_expiry_date %}
                    {{ project.url_expiry_date }}
                    {% if project.url_expiry_days is not null and project.url_expiry_days <= 30 and project.url_expiry_days >= 0 %}
                        <span class="expiry-dot" title="D-30 임박"></span>
                    {% endif %}
                    {% if project.url_expiry_days is not null and project.url_expiry_days < 0 %}
                        <span class="badge badge-danger ml-1">만료</span>
                    {% endif %}
                {% else %}
                    <span class="badge badge-secondary">미계약</span>
                {% endif %}
            </p>
        </div>

        <div class="form-group">
            <label><strong>SSL 만료일</strong></label>
            <p class="form-control-plaintext">
                {% if project.ssl_expiry_date %}
                    {{ project.ssl_expiry_date }}
                    {% if project.ssl_expiry_days is not null and project.ssl_expiry_days <= 30 and project.ssl_expiry_days >= 0 %}
                        <span class="expiry-dot" title="D-30 임박"></span>
                    {% endif %}
                    {% if project.ssl_expiry_days is not null and project.ssl_expiry_days < 0 %}
                        <span class="badge badge-danger ml-1">만료</span>
                    {% endif %}
                {% else %}
                    <span class="badge badge-secondary">미계약</span>
                {% endif %}
            </p>
        </div>

        <div class="form-group">
            <label><strong>호스팅 만료일</strong></label>
            <p class="form-control-plaintext">
                {% if project.hosting_expiry_date %}
                    {{ project.hosting_expiry_date }}
                    {% if project.hosting_expiry_days is not null and project.hosting_expiry_days <= 30 and project.hosting_expiry_days >= 0 %}
                        <span class="expiry-dot" title="D-30 임박"></span>
                    {% endif %}
                    {% if project.hosting_expiry_days is not null and project.hosting_expiry_days < 0 %}
                        <span class="badge badge-danger ml-1">만료</span>
                    {% endif %}
                {% else %}
                    <span class="badge badge-secondary">미계약</span>
                {% endif %}
            </p>
        </div>

        <div class="form-group">
            <label><strong>유지보수 만료일</strong></label>
            <p class="form-control-plaintext">
                {% if project.maintenance_expiry_date %}
                    {{ project.maintenance_expiry_date }}
                    {% if project.maintenance_expiry_days is not null and project.maintenance_expiry_days <= 30 and project.maintenance_expiry_days >= 0 %}
                        <span class="expiry-dot" title="D-30 임박"></span>
                    {% endif %}
                    {% if project.maintenance_expiry_days is not null and project.maintenance_expiry_days < 0 %}
                        <span class="badge badge-danger ml-1">만료</span>
                    {% endif %}
                {% else %}
                    <span class="badge badge-secondary">미계약</span>
                {% endif %}
            </p>
        </div>

        <div class="form-group">
            <label><strong>담당자</strong></label>
            <p class="form-control-plaintext">{{ project.manager ?? '-' }}</p>
        </div>

        <div class="form-group">
            <label><strong>상태</strong></label>
            <p class="form-control-plaintext">
                <span class="badge badge-status badge-{{ project.status }}">{{ project.status }}</span>
            </p>
        </div>

        <div class="form-group">
            <label><strong>메모</strong></label>
            <p class="form-control-plaintext">{{ project.memo|nl2br }}</p>
        </div>
    </div>
</div>

<div class="card shadow-sm mt-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">만료일 빠른 갱신</h6>
    </div>
    <div class="card-body">
        <div class="row">
            {% for field, label in expiry_fields %}
                <div class="col-xl-3 col-md-6 mb-3">
                    <form method="post" action="/admin/project/{{ project.id }}/renew">
                        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                        <input type="hidden" name="expiry_field" value="{{ field }}">
                        <label class="small font-weight-bold">{{ label }}</label>
                        <div class="input-group">
                            <input type="date" name="expiry_date" class="form-control" value="{{ attribute(project, field) != '0000-00-00' ? attribute(project, field) : '' }}" required>
                            <div class="input-group-append">
                                <button type="submit" class="btn btn-outline-primary">저장</button>
                            </div>
                        </div>
                    </form>
                </div>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}

{% extends 'admin/layout/base.html.twig' %}

{% block title %}월 지출내역 | 관리자{% endblock %}
{% block styles %}
<style>
.expense-page{max-width:1480px;margin:2.25rem auto;color:#262626}.expense-head{display:flex;justify-content:space-between;gap:1rem;align-items:flex-end;margin-bottom:1.25rem}.expense-title{margin:0;font-weight:800;font-size:2rem;letter-spacing:-.06rem}.expense-subtitle{margin:.4rem 0 0;color:#767676;font-size:.93rem}.expense-toolbar{display:flex;align-items:center;gap:.5rem}.expense-toolbar select{width:auto;min-width:92px}.expense-summary{background:linear-gradient(135deg,#f5f8ff,#fff);border:1px solid #dce6fa;border-radius:.65rem;padding:1rem 1.25rem;margin-bottom:1.25rem}.summary-label{color:#61708b;font-size:.82rem;font-weight:700}.summary-total{color:#245db3;font-size:1.35rem;font-weight:800}.summary-meta{color:#71809a;font-size:.84rem}.expense-table-card{background:#fff;border:1px solid #e5e7eb;border-radius:.65rem;overflow:hidden;box-shadow:0 .15rem .5rem rgba(31,41,55,.04)}.expense-table{margin:0;min-width:1050px}.expense-table thead th{background:#fafbfc;border-top:0;border-bottom:1px solid #e5e7eb;color:#667085;font-size:.78rem;font-weight:700;padding:.8rem .9rem;white-space:nowrap}.expense-table td{border-color:#edf0f3;color:#343a40;font-size:.9rem;padding:.8rem .9rem;vertical-align:middle}.expense-table tbody tr:hover{background:#fafcff}.person-badge{align-items:center;background:#fff1e5;border-radius:50%;color:#e97612;display:inline-flex;font-size:.72rem;font-weight:800;height:1.6rem;justify-content:center;margin-right:.4rem;width:1.6rem}.item-name{font-weight:700}.account-text{color:#586270}.amount-text{font-variant-numeric:tabular-nums;font-weight:700;text-align:right;white-space:nowrap}.empty-row{color:#98a2b3;padding:4rem!important;text-align:center}@media(max-width:767px){.expense-page{margin-top:1.25rem}.expense-head{align-items:flex-start;flex-direction:column}.expense-toolbar{width:100%;flex-wrap:wrap}.expense-toolbar .btn{margin-left:auto}}
</style>
{% endblock %}

{% block content %}
<main class="expense-page">
  <div class="expense-head"><div><h1 class="expense-title">월 지출내역</h1><p class="expense-subtitle">{{ year }}년 {{ month }}월 지출을 별도 장부로 관리합니다.</p></div>
    <form method="get" class="expense-toolbar"><select name="year" class="form-control form-control-sm" onchange="this.form.submit()">{% for y in years %}<option value="{{ y }}" {{ y == year ? 'selected' : '' }}>{{ y }}년</option>{% endfor %}</select><select name="month" class="form-control form-control-sm" onchange="this.form.submit()">{% for m in months %}<option value="{{ m }}" {{ m == month ? 'selected' : '' }}>{{ m }}월</option>{% endfor %}</select><button type="button" class="btn btn-primary btn-sm px-3" onclick="openExpenseForm()"><i class="fas fa-plus mr-1"></i> 지출 추가</button></form>
  </div>
  <section class="expense-summary d-flex align-items-center justify-content-between"><div><div class="summary-label">{{ year }}년 {{ month }}월 총 지출</div><div class="summary-total">₩{{ summary.total_sum|default(0)|number_format }}</div></div><div class="summary-meta text-right">{{ summary.row_count|default(0) }}건</div></section>
  <section class="expense-table-card"><div class="table-responsive"><table class="table expense-table"><thead><tr><th>날짜</th><th>사람</th><th>항목</th><th class="text-right">금액</th><th>결제계좌</th><th>카드 명의자</th><th>상세설명</th><th class="text-center">관리</th></tr></thead><tbody>
  {% for item in expenses %}<tr data-expense='{{ item|json_encode|e('html_attr') }}'><td>{{ item.expense_date|date('Y년 n월 j일') }}</td><td><span class="person-badge">{{ item.person_name|slice(0, 1) }}</span>{{ item.person_name }}</td><td class="item-name"><i class="far fa-file-alt text-muted mr-2"></i>{{ item.item_name }}{% if item.is_recurring %}<span class="badge badge-info ml-1">반복 {{ item.repeat_count }}개월</span>{% endif %}</td><td class="amount-text">₩{{ item.amount|number_format }}</td><td class="account-text">{{ item.payment_account|default('-') }}</td><td>{{ item.cardholder_name|default('-') }}</td><td>{{ item.description|default('-') }}</td><td class="text-center"><button type="button" class="btn btn-outline-secondary btn-sm edit-expense">수정</button><button type="button" class="btn btn-outline-danger btn-sm delete-expense ml-1" data-id="{{ item.id }}">삭제</button></td></tr>{% else %}<tr><td colspan="8" class="empty-row"><i class="far fa-calendar-times d-block mb-2" style="font-size:1.5rem"></i>등록된 지출 내역이 없습니다.</td></tr>{% endfor %}
  </tbody>{% if expenses %}<tfoot><tr class="bg-light"><td colspan="3" class="font-weight-bold">합계</td><td class="amount-text text-primary">₩{{ summary.total_sum|default(0)|number_format }}</td><td colspan="4"></td></tr></tfoot>{% endif %}</table></div></section>
</main>
<div class="modal fade" id="expenseModal" tabindex="-1"><div class="modal-dialog modal-lg"><div class="modal-content"><form id="expenseForm"><input type="hidden" name="id" id="expenseId"><div class="modal-header"><h5 class="modal-title" id="expenseModalTitle">지출 추가</h5><button type="button" class="close" data-dismiss="modal"><span>&times;</span></button></div><div class="modal-body"><div class="form-row"><div class="form-group col-md-4"><label>날짜</label><input class="form-control" type="date" name="expense_date" id="expenseDate" value="{{ '%04d-%02d-01'|format(year, month) }}" required></div><div class="form-group col-md-4"><label>사람</label><input class="form-control" name="person_name" id="personName" placeholder="예: 우용 최" required></div><div class="form-group col-md-4"><label>금액</label><input class="form-control" type="number" min="1" name="amount" id="expenseAmount" required></div></div><div class="form-group"><label>항목</label><input class="form-control" name="item_name" id="itemName" placeholder="예: 서버 이용료" required></div><div class="form-row"><div class="form-group col-md-6"><label>결제계좌</label><input class="form-control" name="payment_account" id="paymentAccount" placeholder="예: 농협 계좌"></div><div class="form-group col-md-6"><label>카드 명의자</label><input class="form-control" name="cardholder_name" id="cardholderName" placeholder="예: 우용 최"></div></div><div class="form-row align-items-end"><div class="form-group col-md-6 mb-md-0"><div class="custom-control custom-checkbox"><input class="custom-control-input" type="checkbox" name="is_recurring" value="1" id="isRecurring"><label class="custom-control-label" for="isRecurring">매월 반복 등록</label></div></div><div class="form-group col-md-6 mb-0" id="repeatCountGroup" style="display:none"><label>반복 개월 수 <small class="text-muted">(등록월 포함)</small></label><input class="form-control" type="number" min="1" max="120" name="repeat_count" id="repeatCount" value="2"></div></div><div class="form-group mb-0 mt-3"><label>상세설명</label><textarea class="form-control" name="description" id="expenseDescription" rows="3" placeholder="메모 또는 상세 설명을 입력하세요."></textarea></div></div><div class="modal-footer"><button type="button" class="btn btn-light" data-dismiss="modal">취소</button><button class="btn btn-primary" type="submit">저장</button></div></form></div></div></div>
{% endblock %}
{% block scripts %}<script>
const form=document.getElementById('expenseForm');
function toggleRepeat(){document.getElementById('repeatCountGroup').style.display=document.getElementById('isRecurring').checked?'block':'none';}document.getElementById('isRecurring').addEventListener('change',toggleRepeat);
function openExpenseForm(data=null){form.reset();document.getElementById('expenseId').value=data?data.id:'';document.getElementById('expenseModalTitle').textContent=data?'지출 수정':'지출 추가';document.getElementById('expenseDate').value=data?data.expense_date:'{{ '%04d-%02d-01'|format(year, month) }}';if(data){document.getElementById('personName').value=data.person_name||'';document.getElementById('itemName').value=data.item_name||'';document.getElementById('expenseAmount').value=data.amount||'';document.getElementById('paymentAccount').value=data.payment_account||'';document.getElementById('cardholderName').value=data.cardholder_name||'';document.getElementById('expenseDescription').value=data.description||'';document.getElementById('isRecurring').checked=Boolean(Number(data.is_recurring));document.getElementById('repeatCount').value=data.repeat_count||2;}toggleRepeat();$('#expenseModal').modal('show');}
form.addEventListener('submit',async e=>{e.preventDefault();const endpoint=document.getElementById('expenseId').value?'/admin/monthly-expenses/update':'/admin/monthly-expenses/add';const res=await fetch(endpoint,{method:'POST',body:new FormData(form)});const result=await res.json();if(result.success){location.reload();return;}alert('저장 실패: '+(result.message||'다시 시도해 주세요.'));});
document.querySelectorAll('.edit-expense').forEach(btn=>btn.addEventListener('click',()=>openExpenseForm(JSON.parse(btn.closest('tr').dataset.expense))));document.querySelectorAll('.delete-expense').forEach(btn=>btn.addEventListener('click',async()=>{if(!confirm('이 지출 내역을 삭제하시겠습니까?'))return;const res=await fetch('/admin/monthly-expenses/delete',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:'id='+encodeURIComponent(btn.dataset.id)});const result=await res.json();if(result.success)location.reload();else alert('삭제 실패: '+result.message);}));
</script>{% endblock %}

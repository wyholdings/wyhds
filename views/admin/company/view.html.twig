{% extends 'admin/layout/base.html.twig' %}

{% block content %}
<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="h3 mb-0 text-gray-800">업체 정보</h1>
        <p class="text-muted mb-0">{{ company.name }}</p>
    </div>
    <div>
        <a href="/admin/company/list" class="btn btn-sm btn-outline-secondary">목록</a>
        <a href="/admin/company/{{ company.id }}/edit" class="btn btn-sm btn-primary">수정</a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="form-group">
            <label><strong>업체명</strong></label>
            <p class="form-control-plaintext">{{ company.name }}</p>
        </div>

        <div class="form-group">
            <label><strong>사업자등록번호</strong></label>
            <p class="form-control-plaintext">{{ company.business_number ?? '-' }}</p>
        </div>

        <div class="form-group">
            <label><strong>사업자등록증</strong></label>
            <p class="form-control-plaintext">
                {% if company.business_license_file %}
                    <a href="{{ company.business_license_file }}" target="_blank" rel="noopener noreferrer">파일 보기</a>
                {% else %}
                    -
                {% endif %}
            </p>
        </div>

        <div class="form-group">
            <label><strong>업체 타입</strong></label>
            <p class="form-control-plaintext">{{ company.type ?? '-' }}</p>
        </div>

        <div class="form-group">
            <label><strong>계약 시작일</strong></label>
            <p class="form-control-plaintext">{{ company.contract_start ?? '-' }}</p>
        </div>

        <div class="form-group">
            <label><strong>계약 종료일</strong></label>
            <p class="form-control-plaintext">{{ company.contract_end ?? '-' }}</p>
        </div>

        <div class="form-group">
            <label><strong>담당자</strong></label>
            <p class="form-control-plaintext">{{ company.manager ?? '-' }}</p>
        </div>

        <div class="form-group">
            <label><strong>전화번호</strong></label>
            <p class="form-control-plaintext">{{ company.phone ?? '-' }}</p>
        </div>

        <div class="form-group">
            <label><strong>이메일</strong></label>
            <p class="form-control-plaintext">{{ company.email ?? '-' }}</p>
        </div>

        <div class="form-group">
            <label><strong>주소</strong></label>
            <p class="form-control-plaintext">{{ company.address ?? '-' }}</p>
        </div>

        <div class="form-group">
            <label><strong>상태</strong></label>
            <p class="form-control-plaintext">
                <span class="badge badge-status badge-{{ company.status }}">{{ company.status }}</span>
            </p>
        </div>

        <div class="form-group">
            <label><strong>메모</strong></label>
            <p class="form-control-plaintext">{{ company.memo|nl2br }}</p>
        </div>
    </div>
</div>

<div class="card shadow-sm mt-4">
    <div class="card-header py-3 d-flex align-items-center justify-content-between">
        <h6 class="m-0 font-weight-bold text-primary">연결 프로젝트</h6>
        <div>
            <a href="/admin/project/list?company_id={{ company.id }}" class="btn btn-sm btn-outline-primary">프로젝트 목록</a>
            <a href="/admin/project/add" class="btn btn-sm btn-primary">프로젝트 등록</a>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="thead-light">
                    <tr>
                        <th>프로젝트명</th>
                        <th style="width: 180px;">URL</th>
                        <th style="width: 130px;">URL 만료</th>
                        <th style="width: 130px;">SSL 만료</th>
                        <th style="width: 110px;">상태</th>
                        <th style="width: 120px;">관리</th>
                    </tr>
                </thead>
                <tbody>
                    {% for project in projects %}
                    <tr>
                        <td>
                            <a href="/admin/project/{{ project.id }}/view">{{ project.name }}</a>
                            {% if project.manager %}<div class="small text-muted">{{ project.manager }}</div>{% endif %}
                        </td>
                        <td class="small text-truncate" style="max-width: 180px;">
                            {% if project.site_url %}
                                <a href="{{ project.site_url }}" target="_blank" rel="noopener noreferrer">{{ project.site_url }}</a>
                            {% else %}
                                -
                            {% endif %}
                        </td>
                        <td class="small">
                            {% if project.url_expiry_date %}
                                {{ project.url_expiry_date }}
                                {% if project.url_expiry_days is not null and project.url_expiry_days < 0 %}
                                    <span class="badge badge-danger ml-1">만료</span>
                                {% elseif project.url_expiry_days is not null and project.url_expiry_days <= 30 %}
                                    <span class="badge badge-warning ml-1">D-{{ project.url_expiry_days }}</span>
                                {% endif %}
                            {% else %}
                                <span class="badge badge-secondary">미계약</span>
                            {% endif %}
                        </td>
                        <td class="small">
                            {% if project.ssl_expiry_date %}
                                {{ project.ssl_expiry_date }}
                                {% if project.ssl_expiry_days is not null and project.ssl_expiry_days < 0 %}
                                    <span class="badge badge-danger ml-1">만료</span>
                                {% elseif project.ssl_expiry_days is not null and project.ssl_expiry_days <= 30 %}
                                    <span class="badge badge-warning ml-1">D-{{ project.ssl_expiry_days }}</span>
                                {% endif %}
                            {% else %}
                                <span class="badge badge-secondary">미계약</span>
                            {% endif %}
                        </td>
                        <td><span class="badge badge-status badge-{{ project.status }}">{{ project.status }}</span></td>
                        <td>
                            <a href="/admin/project/{{ project.id }}/view" class="btn btn-sm btn-outline-info">보기</a>
                            <a href="/admin/project/{{ project.id }}/edit" class="btn btn-sm btn-outline-warning">수정</a>
                        </td>
                    </tr>
                    {% else %}
                    <tr><td colspan="6" class="text-center text-muted p-4">연결된 프로젝트가 없습니다.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}

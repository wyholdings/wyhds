{% extends 'admin/layout/base.html.twig' %}

{% block content %}
<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="h3 mb-0 text-gray-800">업체 목록</h1>
        <p class="text-muted mb-0">조회 {{ pagination.total }}개 / 전체 {{ summary.total }}개 업체</p>
    </div>
    <div>
        <a href="/admin/company/export{% if export_query %}?{{ export_query }}{% endif %}" class="btn btn-sm btn-outline-success">CSV 다운로드</a>
        <a href="/admin/company/add" class="btn btn-sm btn-primary">+ 업체 등록</a>
    </div>
</div>

<div class="row">
    <div class="col-xl-2 col-md-4 col-6 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body py-3">
                <div class="small text-muted">전체</div>
                <div class="h5 mb-0 font-weight-bold text-gray-800">{{ summary.total }}</div>
            </div>
        </div>
    </div>
    <div class="col-xl-2 col-md-4 col-6 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body py-3">
                <div class="small text-muted">활성</div>
                <div class="h5 mb-0 font-weight-bold text-success">{{ summary.active }}</div>
            </div>
        </div>
    </div>
    <div class="col-xl-2 col-md-4 col-6 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body py-3">
                <div class="small text-muted">보류</div>
                <div class="h5 mb-0 font-weight-bold text-warning">{{ summary.hold }}</div>
            </div>
        </div>
    </div>
    <div class="col-xl-2 col-md-4 col-6 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body py-3">
                <div class="small text-muted">비활성</div>
                <div class="h5 mb-0 font-weight-bold text-secondary">{{ summary.inactive }}</div>
            </div>
        </div>
    </div>
    <div class="col-xl-2 col-md-4 col-6 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body py-3">
                <div class="small text-muted">계약 임박 30일</div>
                <div class="h5 mb-0 font-weight-bold text-danger">{{ summary.due_30 }}</div>
            </div>
        </div>
    </div>
    <div class="col-xl-2 col-md-4 col-6 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body py-3">
                <div class="small text-muted">계약 만료</div>
                <div class="h5 mb-0 font-weight-bold text-danger">{{ summary.expired }}</div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <form method="get" action="/admin/company/list" class="form-row align-items-end">
            <div class="form-group col-lg-4 col-md-6">
                <label class="small font-weight-bold">검색</label>
                <input type="search" name="q" class="form-control" value="{{ filters.q }}" placeholder="업체명, 담당자, 연락처, 이메일">
            </div>
            <div class="form-group col-lg-2 col-md-3">
                <label class="small font-weight-bold">상태</label>
                <select name="status" class="form-control">
                    <option value="">전체</option>
                    <option value="active" {% if filters.status == 'active' %}selected{% endif %}>활성</option>
                    <option value="hold" {% if filters.status == 'hold' %}selected{% endif %}>보류</option>
                    <option value="inactive" {% if filters.status == 'inactive' %}selected{% endif %}>비활성</option>
                </select>
            </div>
            <div class="form-group col-lg-2 col-md-3">
                <label class="small font-weight-bold">타입</label>
                <select name="type" class="form-control">
                    <option value="">전체</option>
                    <option value="client" {% if filters.type == 'client' %}selected{% endif %}>고객사</option>
                    <option value="partner" {% if filters.type == 'partner' %}selected{% endif %}>협력사</option>
                    <option value="internal" {% if filters.type == 'internal' %}selected{% endif %}>내부</option>
                </select>
            </div>
            <div class="form-group col-lg-2 col-md-3">
                <label class="small font-weight-bold">계약 종료</label>
                <select name="contract" class="form-control">
                    <option value="">전체</option>
                    <option value="expired" {% if filters.contract == 'expired' %}selected{% endif %}>만료</option>
                    <option value="7" {% if filters.contract == '7' %}selected{% endif %}>7일 이내</option>
                    <option value="30" {% if filters.contract == '30' %}selected{% endif %}>30일 이내</option>
                    <option value="60" {% if filters.contract == '60' %}selected{% endif %}>60일 이내</option>
                    <option value="none" {% if filters.contract == 'none' %}selected{% endif %}>종료일 없음</option>
                </select>
            </div>
            <div class="form-group col-lg-2 col-md-3">
                <label class="small font-weight-bold">담당자</label>
                <select name="manager" class="form-control">
                    <option value="">전체</option>
                    {% for manager in managers %}
                        <option value="{{ manager }}" {% if filters.manager == manager %}selected{% endif %}>{{ manager }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="form-group col-lg-2 col-md-3 d-flex">
                <button type="submit" class="btn btn-primary flex-fill mr-2">검색</button>
                <a href="/admin/company/list" class="btn btn-outline-secondary">초기화</a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="thead-light">
                    <tr>
                        <th style="width: 80px;">ID</th>
                        <th>업체명</th>
                        <th style="width: 120px;">담당자</th>
                        <th style="width: 160px;">연락처</th>
                        <th style="width: 150px;">계약 종료</th>
                        <th style="width: 120px;">등록일</th>
                        <th style="width: 120px;">상태</th>
                        <th style="width: 180px;">관리</th>
                    </tr>
                </thead>
                <tbody>
                    {% for company in companies %}
                    <tr>
                        <td class="text-muted">{{ company.id }}</td>
                        <td>
                            <a href="/admin/company/{{ company.id }}/view">{{ company.name }}</a>
                            {% if company.type %}<div class="small text-muted">{{ company.type }}</div>{% endif %}
                        </td>
                        <td>{{ company.manager ?? '-' }}</td>
                        <td class="small">{{ company.phone ?? '-' }}</td>
                        <td class="small">
                            {% if company.contract_end %}
                                {{ company.contract_end }}
                                {% if company.contract_end_days is not null and company.contract_end_days < 0 %}
                                    <span class="badge badge-danger ml-1">만료</span>
                                {% elseif company.contract_end_days is not null and company.contract_end_days <= 30 %}
                                    <span class="badge badge-warning ml-1">D-{{ company.contract_end_days }}</span>
                                {% endif %}
                            {% else %}
                                <span class="badge badge-secondary">없음</span>
                            {% endif %}
                        </td>
                        <td class="small">{{ company.created_at|date('Y-m-d') }}</td>
                        <td>
                            <span class="badge badge-status badge-{{ company.status }}">{{ company.status }}</span>
                        </td>
                        <td>
                            <a href="/admin/company/{{ company.id }}/view" class="btn btn-sm btn-outline-info">보기</a>
                            <a href="/admin/company/{{ company.id }}/edit" class="btn btn-sm btn-outline-warning">수정</a>
                            <form method="post" action="/admin/company/{{ company.id }}/delete" class="d-inline" onsubmit="return confirm('삭제할까요?')">
                                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                                <button type="submit" class="btn btn-sm btn-outline-danger">삭제</button>
                            </form>
                        </td>
                    </tr>
                    {% else %}
                    <tr><td colspan="8" class="text-center text-muted p-4">조건에 맞는 업체가 없습니다.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="d-flex align-items-center justify-content-between mb-5">
    <div class="small text-muted">
        {{ pagination.page }} / {{ pagination.total_pages }} 페이지, 페이지당 {{ pagination.per_page }}개
    </div>
    {% if pagination.total_pages > 1 %}
        <nav aria-label="업체 페이지">
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item {% if pagination.page <= 1 %}disabled{% endif %}">
                    <a class="page-link" href="/admin/company/list?{% if pagination.query %}{{ pagination.query }}&{% endif %}page={{ pagination.page - 1 }}">이전</a>
                </li>
                {% for page in 1..pagination.total_pages %}
                    <li class="page-item {% if pagination.page == page %}active{% endif %}">
                        <a class="page-link" href="/admin/company/list?{% if pagination.query %}{{ pagination.query }}&{% endif %}page={{ page }}">{{ page }}</a>
                    </li>
                {% endfor %}
                <li class="page-item {% if pagination.page >= pagination.total_pages %}disabled{% endif %}">
                    <a class="page-link" href="/admin/company/list?{% if pagination.query %}{{ pagination.query }}&{% endif %}page={{ pagination.page + 1 }}">다음</a>
                </li>
            </ul>
        </nav>
    {% endif %}
</div>
{% endblock %}

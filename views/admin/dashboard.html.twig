{# views/admin/dashboard.html.twig #}
{% extends 'admin/layout/base.html.twig' %}

{% block title %}WY Holdings Admin{% endblock %}

{% block content %}
<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="h3 mb-0 text-gray-800">Dashboard</h1>
        <p class="text-muted mb-0">업체/프로젝트 운영 현황</p>
    </div>
    <div>
        <a href="/admin/company/add" class="btn btn-sm btn-outline-primary">업체 등록</a>
        <a href="/admin/project/add" class="btn btn-sm btn-primary">프로젝트 등록</a>
    </div>
</div>

<div class="row">
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-primary shadow h-100 py-2">
            <div class="card-body">
                <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                    전체 프로젝트</div>
                <div class="h5 mb-0 font-weight-bold text-gray-800">{{ project_summary.total }}</div>
                <div class="small text-muted mt-1">진행중 {{ project_summary.active }} / 보류 {{ project_summary.hold }}</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-danger shadow h-100 py-2">
            <div class="card-body">
                <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">
                    프로젝트 만료 관리</div>
                <div class="h5 mb-0 font-weight-bold text-gray-800">{{ project_summary.due_30 }}</div>
                <div class="small text-muted mt-1">30일 이내, 만료 항목 {{ project_summary.expired }}</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-success shadow h-100 py-2">
            <div class="card-body">
                <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                    전체 업체</div>
                <div class="h5 mb-0 font-weight-bold text-gray-800">{{ company_summary.total }}</div>
                <div class="small text-muted mt-1">활성 {{ company_summary.active }} / 보류 {{ company_summary.hold }}</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-warning shadow h-100 py-2">
            <div class="card-body">
                <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                    계약 종료 관리</div>
                <div class="h5 mb-0 font-weight-bold text-gray-800">{{ company_summary.due_30 }}</div>
                <div class="small text-muted mt-1">30일 이내, 만료 업체 {{ company_summary.expired }}</div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-xl-7 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-header py-3 d-flex align-items-center justify-content-between">
                <h6 class="m-0 font-weight-bold text-primary">30일 이내 만료 프로젝트</h6>
                <a href="/admin/project/list?expiry=30" class="small">전체 보기</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="thead-light">
                            <tr>
                                <th>프로젝트</th>
                                <th style="width: 160px;">고객사</th>
                                <th style="width: 130px;">가까운 만료일</th>
                                <th style="width: 90px;">남은일</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for project in expiring_projects %}
                            <tr>
                                <td><a href="/admin/project/{{ project.id }}/view">{{ project.name }}</a></td>
                                <td class="small">{{ project.client_name ?? '-' }}</td>
                                <td class="small">{{ project.nearest_expiry_date }}</td>
                                <td>
                                    <span class="badge badge-warning">D-{{ project.nearest_expiry_days }}</span>
                                </td>
                            </tr>
                            {% else %}
                            <tr><td colspan="4" class="text-center text-muted p-4">30일 이내 만료 프로젝트가 없습니다.</td></tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-5 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-header py-3 d-flex align-items-center justify-content-between">
                <h6 class="m-0 font-weight-bold text-primary">30일 이내 계약 종료 업체</h6>
                <a href="/admin/company/list?contract=30" class="small">전체 보기</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="thead-light">
                            <tr>
                                <th>업체</th>
                                <th style="width: 130px;">계약 종료</th>
                                <th style="width: 90px;">남은일</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for company in contract_due_companies %}
                            <tr>
                                <td>
                                    <a href="/admin/company/{{ company.id }}/view">{{ company.name }}</a>
                                    {% if company.manager %}<div class="small text-muted">{{ company.manager }}</div>{% endif %}
                                </td>
                                <td class="small">{{ company.contract_end }}</td>
                                <td><span class="badge badge-warning">D-{{ company.contract_end_days }}</span></td>
                            </tr>
                            {% else %}
                            <tr><td colspan="3" class="text-center text-muted p-4">30일 이내 계약 종료 업체가 없습니다.</td></tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% extends 'admin/layout/base.html.twig' %}

{% block content %}
<h1>업체 정보</h1>

<div class="form-group">
    <label><strong>기관명/학회명/회사명:</strong></label>
    <p class="form-control-plaintext">{{ inquiry.company }}</p>
</div>

<div class="form-group">
    <label><strong>성함:</strong></label>
    <p class="form-control-plaintext">{{ inquiry.name }}</p>
</div>

<div class="form-group">
    <label><strong>이메일:</strong></label>
    <p class="form-control-plaintext">{{ inquiry.email }}</p>
</div>

<div class="form-group">
    <label><strong>전화번호:</strong></label>
    <p class="form-control-plaintext">{{ inquiry.phone }}</p>
</div>

<div class="form-group">
    <label><strong>예산:</strong></label>
    <p class="form-control-plaintext">
        {% if inquiry.budget %}
            {{ inquiry.budget|number_format }}만원
        {% else %}
            -
        {% endif %}
    </p>
</div>

<div class="form-group">
    <label><strong>내용:</strong></label>
    <p class="form-control-plaintext">{{ inquiry.message|nl2br }}</p>
</div>

<a href="/admin/inquiry/list" class="btn btn-secondary">목록</a>
{% endblock %}

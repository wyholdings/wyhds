{% extends 'layout/base.html.twig' %}

{% block body %}
<div id="wrap" >

<div id="custom-cursor">
  <div class="pulse-ring"></div>
  <div class="pulse-ring"></div>
  <div class="pulse-ring"></div>
</div>

    <section class="subcon port">
        <p class="bgtxt"><span>WY</span>D&S</p>
        <div class="title">
            <h3>
                <span>PORTFOLIO</span>
                포트폴리오
            </h3>
        </div>

        <div class="subtab">
            <div class="tabs">
                <a href="" class="on">홈페이지</a>
                <a href="">편집디자인</a>
            </div>
        </div>

        <div class="port_list" data-aos="fade-up" data-aos-duration="2000">
            {% if portfolios|default([])|length > 0 %}
                {% for portfolio in portfolios %}
                    <div class="box">
                        <a href="/portfolio/{{ portfolio.id }}">
                            <div class="thumb">
                                <img src="{{ portfolio.thumbnail_image|default('') ? portfolio.thumbnail_image : (portfolio.body_image ? portfolio.body_image : '/images/image.png') }}" alt="{{ portfolio.title }}">
                            </div>
                            <div class="tbox">
                                <h3>{{ portfolio.title }}</h3>
                                <p>{{ portfolio.subtitle }}</p>
                            </div>
                        </a>
                    </div>
                {% endfor %}
            {% else %}
            <div class="box">
                <a href="/portfolio/1">
                    <div class="thumb">
                        <img src="../images/siontech.jpg" alt="(주)시온텍">
                    </div>
                    <div class="tbox">
                        <h3>(주)시온텍</h3>
                        <p>기업 홈페이지 제작</p>
                    </div>
                </a>
            </div>
            <div class="box">
                <a href="">
                    <div class="thumb">
                        <img src="../images/karp_thumb.jpg" alt="대한방사선방어학회">
                    </div>
                    <div class="tbox">
                        <h3>대한방사선방어학회</h3>
                        <p>학회 홈페이지 제작, 학술대회 시스템 </p>
                    </div>
                </a>
            </div>
            <div class="box">
                <a href="">
                    <div class="thumb">
                        <img src="../images/onjabak.jpg" alt="온자박푸드몰">
                    </div>
                    <div class="tbox">
                        <h3>온자박푸드</h3>
                        <p>쇼핑몰 홈페이지 제작</p>
                    </div>
                </a>
            </div>
            
            <div class="box">
                <a href="">
                    <div class="thumb">
                        <img src="../images/oda_thumb.jpg" alt="2025개발협력주간">
                    </div>
                    <div class="tbox">
                        <h3>2025 개발협력주간</h3>
                        <p>정부 행사 홈페이지 제작</p>
                    </div>
                </a>
            </div>
            
            <div class="box">
                <a href="">
                    <div class="thumb">
                        <img src="../images/gllc_thumb.jpg" alt="경기 글로벌 평생학습 리더십 컨퍼런스">
                    </div>
                    <div class="tbox">
                        <h3>경기 글로벌 평생학습 리더십 컨퍼런스</h3>
                        <p>컨퍼런스 홈페이지 제작</p>
                    </div>
                </a>
            </div>

            <div class="box">
                <a href="">
                    <div class="thumb">
                        <img src="../images/icfc_thumb.jpg" alt="제3회 사기방지 국제컨퍼런스">
                    </div>
                    <div class="tbox">
                        <h3>제3회 사기방지 국제컨퍼런스</h3>
                        <p>국제컨퍼런스 홈페이지 제작</p>
                    </div>
                </a>
            </div>

            <div class="box">
                <a href="">
                    <div class="thumb">
                        <img src="../images/east_thumb.jpg" alt="2025 동아시아미래포럼">
                    </div>
                    <div class="tbox">
                        <h3>2025 동아시아미래포럼</h3>
                        <p>국제포럼 홈페이지 제작</p>
                    </div>
                </a>
            </div>
            {% endif %}
        </div>
    </section>

    {# {% include 'partials/_contact.html.twig' %} #}

<script>
    const cursor = document.getElementById('custom-cursor');
    let mx = 0, my = 0, cx = 0, cy = 0;

    function lerp(a, b, t) { return a + (b - a) * t; }

    (function animate() {
    cx = lerp(cx, mx, 0.12);
    cy = lerp(cy, my, 0.12);
    cursor.style.left = cx + 'px';
    cursor.style.top  = cy + 'px';
    requestAnimationFrame(animate);
    })();

    document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; });

    document.querySelectorAll('.port_list .box a').forEach(card => {
    card.addEventListener('mouseenter', () => cursor.classList.add('visible'));
    card.addEventListener('mouseleave', () => cursor.classList.remove('visible'));
    });


    
</script>
  
</div>
{% endblock %}

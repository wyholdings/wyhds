{% set ad_position = position|default('middle') %}
{% set ad_key = ad_position == 'after-faq' ? 'after_faq' : ad_position %}
{% set ad_slot = attribute(adsense.slots|default({}), ad_key)|default(adsense.slots.default|default('8432108065')) %}
{% set ad_client = adsense.client|default('ca-pub-5028641394927049') %}

<div class="wy-ad-slot wy-ad-{{ ad_position }}" data-ad-position="{{ ad_position }}">
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-format="fluid"
         data-ad-layout-key="-fb+5w+4e-db+86"
         data-ad-client="{{ ad_client }}"
         data-ad-slot="{{ ad_slot }}"></ins>
    <script>
        (function () {
            var slot = document.currentScript.previousElementSibling;
            var wrapper = document.currentScript.parentElement;

            function updateVisibility() {
                var status = slot.getAttribute('data-ad-status');
                if (status === 'filled') {
                    wrapper.classList.add('is-ad-filled');
                    wrapper.classList.remove('is-ad-unfilled');
                } else if (status === 'unfilled') {
                    wrapper.classList.remove('is-ad-filled');
                    wrapper.classList.add('is-ad-unfilled');
                }
            }

            new MutationObserver(updateVisibility).observe(slot, {
                attributes: true,
                attributeFilter: ['data-ad-status']
            });
            updateVisibility();
            (adsbygoogle = window.adsbygoogle || []).push({});
        })();
    </script>
</div>

{% extends 'layout/base.html.twig' %}

{% block styles %}
    <link href="/assets/css/tools.css" rel="stylesheet" />
    <script type="application/ld+json">
{{ {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    'name': 'WY Tools',
    'url': canonical_url,
    'description': description,
    'hasPart': tools|map(item => {
        '@type': 'WebApplication',
        'name': item.name,
        'url': 'https://wyhds.com' ~ item.url,
        'description': item.description,
        'applicationCategory': 'WebApplication',
        'operatingSystem': 'Any'
    })
}|json_encode(constant('JSON_UNESCAPED_UNICODE') b-or constant('JSON_UNESCAPED_SLASHES'))|raw }}
    </script>
{% endblock %}

{% block body %}
<div id="wrap" class="tools-page wy-tools" data-tools-index='{{ search_index|json_encode(constant('JSON_UNESCAPED_UNICODE') b-or constant('JSON_UNESCAPED_SLASHES'))|e('html_attr') }}'>
    <section class="wy-hero">
        <div class="tools-inner">
            <p class="eyebrow">WY Tools</p>
            <h1>무료 온라인 도구 모음</h1>
            <p>개발, AI, PDF, 이미지, 텍스트, 계산기까지 하나의 플랫폼에서 빠르게 처리하세요.</p>
            <div class="wy-search">
                <input type="search" data-tool-search placeholder="필요한 도구를 검색하세요. 예: PDF, JSON, 이미지, 계산기" autocomplete="off">
                <div class="search-suggestions" data-search-suggestions></div>
            </div>
            <div class="hero-actions">
                <button type="button" class="mode-toggle" data-theme-toggle>다크 모드</button>
                <a href="/contact">기업 문의</a>
            </div>
        </div>
    </section>

    {% include 'tools/partials/_ad_slot.html.twig' with { position: 'top' } %}

    <section class="wy-section personal-tools">
        <div class="tools-inner two-columns">
            <div>
                <div class="section-head">
                    <h2>즐겨찾기</h2>
                    <p>자주 쓰는 도구를 고정해 빠르게 다시 여세요.</p>
                </div>
                <div class="compact-list" data-favorite-tools></div>
            </div>
            <div>
                <div class="section-head">
                    <h2>최근 사용</h2>
                    <p>방금 사용한 도구를 이어서 사용할 수 있습니다.</p>
                </div>
                <div class="compact-list" data-recent-tools></div>
            </div>
        </div>
    </section>

    <section class="wy-section">
        <div class="tools-inner">
            <div class="section-head">
                <h2>인기 도구</h2>
                <p>최근 사용량과 기본 추천을 반영한 대표 도구입니다.</p>
            </div>
            <div class="wy-tool-grid" data-tool-grid>
                {% for item in popular_tools %}
                    {% include 'tools/partials/_tool_card.html.twig' with { item: item } %}
                {% endfor %}
            </div>
        </div>
    </section>

    <section class="wy-section work-recommendation-section">
        <div class="tools-inner">
            <div class="section-head">
                <h2>업무별 추천</h2>
                <p>지금 하려는 업무를 기준으로 필요한 도구를 골라보세요.</p>
            </div>
            <div class="work-recommendation-grid">
                {% for group in work_recommendations %}
                    <article class="work-recommendation-card">
                        <h3>{{ group.title }}</h3>
                        <p>{{ group.description }}</p>
                        <div class="work-recommendation-tools">
                            {% for item in group.tools %}
                                <a href="{{ item.url }}">{{ item.name }}<span>열기</span></a>
                            {% endfor %}
                        </div>
                    </article>
                {% endfor %}
            </div>
        </div>
    </section>

    <section class="wy-section recent-tools-section">
        <div class="tools-inner">
            <div class="section-head">
                <h2>최근 추가</h2>
                <p>새로 추가됐거나 최근 고도화한 도구입니다.</p>
            </div>
            <div class="wy-tool-grid recent-tool-grid">
                {% for item in recent_tools %}
                    {% include 'tools/partials/_tool_card.html.twig' with { item: item } %}
                {% endfor %}
            </div>
        </div>
    </section>

    <section class="wy-section category-band">
        <div class="tools-inner">
            <div class="section-head">
                <h2>전체 카테고리</h2>
                <p>더 많은 도구를 기능 종류별로 찾아보세요.</p>
            </div>
            <div class="category-grid">
                {% for category in categories %}
                    <a href="{{ category.url }}">
                        <strong>{{ category.name }}</strong>
                        <span>{{ category.label }} · {{ category.count }}개 도구</span>
                    </a>
                {% endfor %}
            </div>
        </div>
    </section>

    {% include 'tools/partials/_ad_slot.html.twig' with { position: 'middle' } %}

    <section class="wy-section seo-copy">
        <div class="tools-inner">
            <h2>WY Tools는 누구나 쓰는 무료 온라인 도구 플랫폼입니다.</h2>
            <p>WY Tools는 개발자 전용 사이트가 아니라 회사원, 디자이너, 학생, AI 사용자, 일반 사용자가 모두 사용할 수 있는 생산성 도구 플랫폼을 목표로 합니다. JSON 정리, PDF 작업, 이미지 변환, 텍스트 편집, 계산기, AI 프롬프트 보조 도구를 한 곳에서 제공해 반복 업무 시간을 줄입니다.</p>
            <p>가능한 기능은 브라우저에서 처리해 서버 부하를 줄이고, 입력 데이터를 저장하지 않는 방향을 우선합니다. 앞으로 Premium 기능, API, 기업 문의 기능을 붙일 수 있도록 카테고리와 도구 메타데이터 기반 구조로 확장합니다.</p>
        </div>
    </section>

    <section class="wy-section faq-section">
        <div class="tools-inner">
            <div class="section-head">
                <h2>FAQ</h2>
                <p>WY Tools 사용 전 자주 묻는 질문입니다.</p>
            </div>
            <div class="faq-list">
                <details open><summary>WY Tools는 무료인가요?</summary><p>현재 제공되는 기본 온라인 도구는 무료로 사용할 수 있습니다. 향후 대량 처리, API, 팀 기능은 Premium으로 확장할 수 있습니다.</p></details>
                <details><summary>개발자가 아니어도 사용할 수 있나요?</summary><p>네. PDF, 이미지, 텍스트, 계산기, AI 도구처럼 일반 업무와 학습에 필요한 도구도 함께 제공합니다.</p></details>
                <details><summary>입력한 데이터는 저장되나요?</summary><p>가능한 기능은 브라우저에서 처리하며 입력값을 서버에 저장하지 않는 구조를 우선합니다.</p></details>
            </div>
        </div>
    </section>

    {% include 'tools/partials/_ad_slot.html.twig' with { position: 'footer' } %}
</div>
{% endblock %}

{% block scripts %}
    <script src="/assets/js/tools.js"></script>
{% endblock %}

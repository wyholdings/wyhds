{% extends 'layout/base.html.twig' %}

{% block styles %}
    <link href="/assets/css/tools.css" rel="stylesheet" />
    <script type="application/ld+json">
{{ {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    'itemListElement': [
        {'@type': 'ListItem', 'position': 1, 'name': 'WY Tools', 'item': 'https://wyhds.com/tools'},
        {'@type': 'ListItem', 'position': 2, 'name': category.name|default('Tools'), 'item': 'https://wyhds.com/tools/category/' ~ tool.category},
        {'@type': 'ListItem', 'position': 3, 'name': tool.name, 'item': canonical_url}
    ]
}|json_encode(constant('JSON_UNESCAPED_UNICODE') b-or constant('JSON_UNESCAPED_SLASHES'))|raw }}
    </script>
    <script type="application/ld+json">
{{ {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    'mainEntity': tool.faqs|map(faq => {
        '@type': 'Question',
        'name': faq.q,
        'acceptedAnswer': {'@type': 'Answer', 'text': faq.a}
    })
}|json_encode(constant('JSON_UNESCAPED_UNICODE') b-or constant('JSON_UNESCAPED_SLASHES'))|raw }}
    </script>
    <script type="application/ld+json">
{{ {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    'name': tool.name,
    'url': canonical_url,
    'description': tool.description,
    'applicationCategory': 'WebApplication',
    'operatingSystem': 'Any',
    'offers': {'@type': 'Offer', 'price': '0', 'priceCurrency': 'KRW'}
}|json_encode(constant('JSON_UNESCAPED_UNICODE') b-or constant('JSON_UNESCAPED_SLASHES'))|raw }}
    </script>
{% endblock %}

{% block body %}
<div id="wrap" class="tools-page wy-tools tool-detail-page" data-tool="{{ tool.widget|default(tool.slug) }}" data-tool-slug="{{ tool.slug }}" data-tools-index='{{ search_index|json_encode(constant('JSON_UNESCAPED_UNICODE') b-or constant('JSON_UNESCAPED_SLASHES'))|e('html_attr') }}'>
    <section class="wy-hero compact">
        <div class="tools-inner">
            <nav class="breadcrumb" aria-label="Breadcrumb">
                <a href="/tools">WY Tools</a>
                <span>/</span>
                <a href="/tools/category/{{ tool.category }}">{{ category.name|default(tool.category) }}</a>
                <span>/</span>
                <strong>{{ tool.name }}</strong>
            </nav>
            <p class="eyebrow">{{ category.name|default('Tool') }}</p>
            <h1>{{ tool.h1 }}</h1>
            <p>{{ tool.description }}</p>
            <div class="hero-actions">
                <button type="button" class="mode-toggle" data-theme-toggle>Dark Mode</button>
                <button type="button" class="mode-toggle" data-share>Share</button>
                <button type="button" class="mode-toggle" data-favorite="{{ tool.slug }}">Favorite</button>
            </div>
        </div>
    </section>

    {% include 'tools/partials/_ad_slot.html.twig' with { position: 'top' } %}

    <section class="tool-body">
        <div class="tools-inner tool-layout">
            <main>
                <div class="tool-panel">
                    {% if tool.widget in ['json-formatter', 'base64', 'url-encode'] %}
                        <label for="tool-input">Input</label>
                        <textarea id="tool-input" class="tool-textarea" spellcheck="false"></textarea>
                        <div class="tool-actions">
                            {% if tool.widget == 'json-formatter' %}
                                <button type="button" class="tool-btn primary" data-action="json-format">Format</button>
                                <button type="button" class="tool-btn" data-action="json-minify">Minify</button>
                            {% elseif tool.widget == 'base64' %}
                                <button type="button" class="tool-btn primary" data-action="base64-encode">Encode</button>
                                <button type="button" class="tool-btn" data-action="base64-decode">Decode</button>
                            {% else %}
                                <button type="button" class="tool-btn primary" data-action="url-encode">Encode</button>
                                <button type="button" class="tool-btn" data-action="url-decode">Decode</button>
                            {% endif %}
                            <button type="button" class="tool-btn" data-copy="#tool-output">Copy</button>
                            <button type="button" class="tool-btn" data-download="#tool-output">Download</button>
                        </div>
                        <label for="tool-output">Result</label>
                        <textarea id="tool-output" class="tool-textarea" readonly spellcheck="false"></textarea>
                    {% elseif tool.widget == 'json-validator' %}
                        <label for="tool-input">JSON Input</label>
                        <textarea id="tool-input" class="tool-textarea" spellcheck="false" placeholder='{"name":"WY Tools"}'></textarea>
                        <div class="tool-actions">
                            <button type="button" class="tool-btn primary" data-action="json-validate">Validate</button>
                            <button type="button" class="tool-btn" data-action="json-format">Format</button>
                        </div>
                        <div class="result-grid">
                            <div><span>Status</span><strong id="json-valid-status">-</strong></div>
                            <div><span>Type</span><strong id="json-valid-type">-</strong></div>
                        </div>
                        <label for="tool-output">Formatted JSON</label>
                        <textarea id="tool-output" class="tool-textarea" readonly spellcheck="false"></textarea>
                    {% elseif tool.widget == 'jwt-decoder' %}
                        <label for="jwt-input">JWT Token</label>
                        <textarea id="jwt-input" class="tool-textarea small" spellcheck="false" placeholder="eyJhbGciOi..."></textarea>
                        <div class="tool-actions">
                            <button type="button" class="tool-btn primary" data-action="jwt-decode">Decode</button>
                            <button type="button" class="tool-btn" data-copy="#jwt-payload">Copy Payload</button>
                        </div>
                        <label for="jwt-header">Header</label>
                        <textarea id="jwt-header" class="tool-textarea small" readonly spellcheck="false"></textarea>
                        <label for="jwt-payload">Payload</label>
                        <textarea id="jwt-payload" class="tool-textarea" readonly spellcheck="false"></textarea>
                    {% elseif tool.widget == 'regex-tester' %}
                        <label for="regex-pattern">Regex Pattern</label>
                        <input id="regex-pattern" class="tool-input mono" type="text" placeholder="\b[A-Z0-9._%+-]+@[A-Z0-9.-]+\.[A-Z]{2,}\b">
                        <label for="regex-flags">Flags</label>
                        <input id="regex-flags" class="tool-input mono" type="text" value="gi">
                        <label for="tool-input">Test Text</label>
                        <textarea id="tool-input" class="tool-textarea" spellcheck="false"></textarea>
                        <div class="tool-actions">
                            <button type="button" class="tool-btn primary" data-action="regex-test">Test Regex</button>
                            <button type="button" class="tool-btn" data-copy="#tool-output">Copy Matches</button>
                        </div>
                        <div class="result-grid"><div><span>Matches</span><strong id="regex-count">0</strong></div><div><span>Status</span><strong id="regex-status">-</strong></div></div>
                        <label for="tool-output">Matches</label>
                        <textarea id="tool-output" class="tool-textarea small" readonly spellcheck="false"></textarea>
                    {% elseif tool.widget == 'sql-formatter' %}
                        <label for="tool-input">SQL Input</label>
                        <textarea id="tool-input" class="tool-textarea" spellcheck="false" placeholder="select id,name from users where status='active' order by id desc"></textarea>
                        <div class="tool-actions">
                            <button type="button" class="tool-btn primary" data-action="sql-format">Format SQL</button>
                            <button type="button" class="tool-btn" data-action="sql-minify">Minify</button>
                            <button type="button" class="tool-btn" data-copy="#tool-output">Copy</button>
                            <button type="button" class="tool-btn" data-download="#tool-output">Download</button>
                        </div>
                        <label for="tool-output">Result</label>
                        <textarea id="tool-output" class="tool-textarea" readonly spellcheck="false"></textarea>
                    {% elseif tool.widget == 'json-csv' %}
                        <label for="tool-input">JSON Input</label>
                        <textarea id="tool-input" class="tool-textarea" spellcheck="false" placeholder='[{"name":"WY Tools","type":"platform"}]'></textarea>
                        <div class="tool-actions">
                            <button type="button" class="tool-btn primary" data-action="json-to-csv">JSON to CSV</button>
                            <button type="button" class="tool-btn" data-action="csv-to-json">CSV to JSON</button>
                            <button type="button" class="tool-btn" data-copy="#tool-output">Copy</button>
                            <button type="button" class="tool-btn" data-download="#tool-output">Download</button>
                        </div>
                        <label for="tool-output">Result</label>
                        <textarea id="tool-output" class="tool-textarea" readonly spellcheck="false"></textarea>
                    {% elseif tool.widget == 'json-xml' %}
                        <label for="tool-input">JSON or XML Input</label>
                        <textarea id="tool-input" class="tool-textarea" spellcheck="false" placeholder='{"tool":"WY Tools","free":true}'></textarea>
                        <div class="tool-actions">
                            <button type="button" class="tool-btn primary" data-action="json-to-xml">JSON to XML</button>
                            <button type="button" class="tool-btn" data-action="xml-to-json">XML to JSON</button>
                            <button type="button" class="tool-btn" data-copy="#tool-output">Copy</button>
                            <button type="button" class="tool-btn" data-download="#tool-output">Download</button>
                        </div>
                        <label for="tool-output">Result</label>
                        <textarea id="tool-output" class="tool-textarea" readonly spellcheck="false"></textarea>
                    {% elseif tool.widget == 'csv-viewer' %}
                        <label for="tool-input">CSV Input</label>
                        <textarea id="tool-input" class="tool-textarea" spellcheck="false" placeholder="name,type&#10;WY Tools,platform"></textarea>
                        <div class="tool-actions">
                            <button type="button" class="tool-btn primary" data-action="csv-view">View CSV</button>
                            <button type="button" class="tool-btn" data-action="csv-to-json">CSV to JSON</button>
                            <button type="button" class="tool-btn" data-copy="#tool-output">Copy JSON</button>
                        </div>
                        <div class="csv-preview" id="csv-preview"></div>
                        <label for="tool-output">JSON Result</label>
                        <textarea id="tool-output" class="tool-textarea small" readonly spellcheck="false"></textarea>
                    {% elseif tool.widget == 'md5' %}
                        <label for="tool-input">Text</label>
                        <textarea id="tool-input" class="tool-textarea" spellcheck="false"></textarea>
                        <div class="tool-actions">
                            <button type="button" class="tool-btn primary" data-action="md5-generate">Generate MD5</button>
                            <button type="button" class="tool-btn" data-copy="#tool-output">Copy</button>
                            <button type="button" class="tool-btn" data-download="#tool-output">Download</button>
                        </div>
                        <label for="tool-output">MD5 Hash</label>
                        <textarea id="tool-output" class="tool-textarea small" readonly spellcheck="false"></textarea>
                    {% elseif tool.widget == 'prompt-formatter' %}
                        <label for="tool-input">Prompt Draft</label>
                        <textarea id="tool-input" class="tool-textarea" spellcheck="false" placeholder="AI에게 요청할 내용을 자유롭게 입력하세요."></textarea>
                        <label for="prompt-role">Role</label>
                        <input id="prompt-role" class="tool-input" type="text" value="You are a helpful assistant.">
                        <div class="tool-actions">
                            <button type="button" class="tool-btn primary" data-action="prompt-format">Format Prompt</button>
                            <button type="button" class="tool-btn" data-copy="#tool-output">Copy</button>
                            <button type="button" class="tool-btn" data-download="#tool-output">Download</button>
                        </div>
                        <label for="tool-output">Formatted Prompt</label>
                        <textarea id="tool-output" class="tool-textarea" readonly spellcheck="false"></textarea>
                    {% elseif tool.widget == 'prompt-optimizer' %}
                        <label for="tool-input">Original Prompt</label>
                        <textarea id="tool-input" class="tool-textarea" spellcheck="false" placeholder="개선할 프롬프트를 입력하세요."></textarea>
                        <div class="tool-checks">
                            <label><input type="checkbox" id="opt-role" checked> Role</label>
                            <label><input type="checkbox" id="opt-context" checked> Context</label>
                            <label><input type="checkbox" id="opt-output" checked> Output format</label>
                            <label><input type="checkbox" id="opt-constraints" checked> Constraints</label>
                        </div>
                        <div class="tool-actions">
                            <button type="button" class="tool-btn primary" data-action="prompt-optimize">Optimize Prompt</button>
                            <button type="button" class="tool-btn" data-copy="#tool-output">Copy</button>
                            <button type="button" class="tool-btn" data-download="#tool-output">Download</button>
                        </div>
                        <label for="tool-output">Optimized Prompt</label>
                        <textarea id="tool-output" class="tool-textarea" readonly spellcheck="false"></textarea>
                    {% elseif tool.widget == 'token-counter' %}
                        <label for="tool-input">Text</label>
                        <textarea id="tool-input" class="tool-textarea" spellcheck="false" placeholder="토큰 수를 추정할 텍스트를 입력하세요."></textarea>
                        <div class="tool-actions">
                            <button type="button" class="tool-btn primary" data-action="token-count">Count Tokens</button>
                        </div>
                        <div class="result-grid three">
                            <div><span>Estimated tokens</span><strong id="token-estimate">0</strong></div>
                            <div><span>Characters</span><strong id="token-chars">0</strong></div>
                            <div><span>Words</span><strong id="token-words">0</strong></div>
                        </div>
                        <p class="tool-note">모델별 실제 토큰 수와 다를 수 있는 브라우저 기반 추정치입니다.</p>
                    {% elseif tool.widget == 'timestamp' %}
                        <div class="tool-current"><span>Current Unix Timestamp</span><strong id="current-timestamp">-</strong></div>
                        <label for="timestamp-input">Timestamp</label>
                        <input id="timestamp-input" class="tool-input" type="text" inputmode="numeric">
                        <div class="tool-actions">
                            <button type="button" class="tool-btn primary" data-action="timestamp-to-date">Convert to Date</button>
                            <button type="button" class="tool-btn" data-action="timestamp-now">Use Now</button>
                        </div>
                        <div class="result-grid"><div><span>Local</span><strong id="timestamp-local">-</strong></div><div><span>UTC</span><strong id="timestamp-utc">-</strong></div></div>
                        <label for="date-input">Date Time</label>
                        <input id="date-input" class="tool-input" type="datetime-local">
                        <button type="button" class="tool-btn" data-action="date-to-timestamp">Convert to Timestamp</button>
                        <input id="date-timestamp-output" class="tool-input" type="text" readonly>
                    {% elseif tool.widget == 'uuid' %}
                        <label for="uuid-count">Count</label>
                        <input id="uuid-count" class="tool-input" type="number" min="1" max="50" value="5">
                        <div class="tool-actions"><button type="button" class="tool-btn primary" data-action="uuid-generate">Generate</button><button type="button" class="tool-btn" data-copy="#tool-output">Copy</button><button type="button" class="tool-btn" data-download="#tool-output">Download</button></div>
                        <textarea id="tool-output" class="tool-textarea" readonly spellcheck="false"></textarea>
                    {% elseif tool.widget == 'password-generator' %}
                        <label for="password-length">Length</label>
                        <input id="password-length" class="tool-input" type="number" min="8" max="128" value="16">
                        <div class="tool-checks">
                            <label><input type="checkbox" id="pw-upper" checked> Uppercase</label>
                            <label><input type="checkbox" id="pw-lower" checked> Lowercase</label>
                            <label><input type="checkbox" id="pw-number" checked> Numbers</label>
                            <label><input type="checkbox" id="pw-symbol" checked> Symbols</label>
                        </div>
                        <div class="tool-actions"><button type="button" class="tool-btn primary" data-action="password-generate">Generate</button><button type="button" class="tool-btn" data-copy="#password-output">Copy</button></div>
                        <input id="password-output" class="tool-input mono" type="text" readonly>
                    {% elseif tool.widget == 'hash-generator' %}
                        <label for="tool-input">Text</label>
                        <textarea id="tool-input" class="tool-textarea" spellcheck="false"></textarea>
                        <label for="hash-algorithm">Algorithm</label>
                        <select id="hash-algorithm" class="tool-input"><option>SHA-256</option><option>SHA-1</option><option>SHA-384</option><option>SHA-512</option></select>
                        <div class="tool-actions"><button type="button" class="tool-btn primary" data-action="hash-generate">Generate</button><button type="button" class="tool-btn" data-copy="#tool-output">Copy</button><button type="button" class="tool-btn" data-download="#tool-output">Download</button></div>
                        <textarea id="tool-output" class="tool-textarea small" readonly spellcheck="false"></textarea>
                    {% elseif tool.widget == 'qr-code' %}
                        <label for="tool-input">URL or Text</label>
                        <textarea id="tool-input" class="tool-textarea small" spellcheck="false" placeholder="https://wyhds.com"></textarea>
                        <div class="tool-actions"><button type="button" class="tool-btn primary" data-action="qr-generate">Generate</button><button type="button" class="tool-btn" data-action="qr-download">Download PNG</button></div>
                        <div class="qr-preview" id="qr-preview"></div>
                    {% elseif tool.widget == 'cron-helper' %}
                        <label for="cron-input">Cron Expression</label>
                        <input id="cron-input" class="tool-input mono" type="text" value="0 9 * * 1-5">
                        <div class="preset-row"><button type="button" data-cron="* * * * *">Every minute</button><button type="button" data-cron="0 * * * *">Hourly</button><button type="button" data-cron="0 0 * * *">Daily</button><button type="button" data-cron="0 9 * * 1-5">Weekdays 09:00</button></div>
                        <div class="tool-actions"><button type="button" class="tool-btn primary" data-action="cron-analyze">Analyze</button><button type="button" class="tool-btn" data-copy="#cron-input">Copy</button></div>
                        <div id="cron-output" class="cron-output"></div>
                    {% elseif tool.widget == 'color-converter' %}
                        <label for="color-picker">Color</label>
                        <input id="color-picker" class="color-picker" type="color" value="#005bac">
                        <label for="hex-input">HEX</label>
                        <input id="hex-input" class="tool-input mono" type="text" value="#005bac">
                        <button type="button" class="tool-btn primary" data-action="color-convert">Convert</button>
                        <div class="color-preview" id="color-preview"></div>
                        <div class="result-grid three"><div><span>HEX</span><strong id="color-hex">-</strong></div><div><span>RGB</span><strong id="color-rgb">-</strong></div><div><span>HSL</span><strong id="color-hsl">-</strong></div></div>
                    {% elseif tool.widget == 'word-counter' %}
                        <label for="tool-input">Text</label>
                        <textarea id="tool-input" class="tool-textarea" spellcheck="false" placeholder="분석할 텍스트를 입력하세요."></textarea>
                        <div class="result-grid three">
                            <div><span>Characters</span><strong id="wc-chars">0</strong></div>
                            <div><span>Words</span><strong id="wc-words">0</strong></div>
                            <div><span>Lines</span><strong id="wc-lines">0</strong></div>
                            <div><span>Sentences</span><strong id="wc-sentences">0</strong></div>
                            <div><span>Paragraphs</span><strong id="wc-paragraphs">0</strong></div>
                            <div><span>Bytes</span><strong id="wc-bytes">0</strong></div>
                        </div>
                    {% elseif tool.widget == 'case-converter' %}
                        <label for="tool-input">Text</label>
                        <textarea id="tool-input" class="tool-textarea" spellcheck="false" placeholder="변환할 텍스트를 입력하세요."></textarea>
                        <div class="tool-actions">
                            <button type="button" class="tool-btn primary" data-action="case-upper">UPPERCASE</button>
                            <button type="button" class="tool-btn" data-action="case-lower">lowercase</button>
                            <button type="button" class="tool-btn" data-action="case-title">Title Case</button>
                            <button type="button" class="tool-btn" data-action="case-sentence">Sentence case</button>
                            <button type="button" class="tool-btn" data-copy="#tool-output">Copy</button>
                        </div>
                        <label for="tool-output">Result</label>
                        <textarea id="tool-output" class="tool-textarea" readonly spellcheck="false"></textarea>
                    {% elseif tool.widget == 'remove-duplicate-lines' %}
                        <label for="tool-input">Lines</label>
                        <textarea id="tool-input" class="tool-textarea" spellcheck="false" placeholder="중복 제거할 줄 목록을 입력하세요."></textarea>
                        <div class="tool-checks">
                            <label><input type="checkbox" id="dedupe-trim" checked> Trim lines</label>
                            <label><input type="checkbox" id="dedupe-case"> Case sensitive</label>
                            <label><input type="checkbox" id="dedupe-empty"> Keep empty lines</label>
                        </div>
                        <div class="tool-actions">
                            <button type="button" class="tool-btn primary" data-action="dedupe-lines">Remove Duplicates</button>
                            <button type="button" class="tool-btn" data-copy="#tool-output">Copy</button>
                            <button type="button" class="tool-btn" data-download="#tool-output">Download</button>
                        </div>
                        <label for="tool-output">Result</label>
                        <textarea id="tool-output" class="tool-textarea" readonly spellcheck="false"></textarea>
                    {% elseif tool.widget == 'lorem-ipsum' %}
                        <label for="lorem-count">Paragraphs</label>
                        <input id="lorem-count" class="tool-input" type="number" min="1" max="20" value="3">
                        <div class="tool-actions">
                            <button type="button" class="tool-btn primary" data-action="lorem-generate">Generate</button>
                            <button type="button" class="tool-btn" data-copy="#tool-output">Copy</button>
                            <button type="button" class="tool-btn" data-download="#tool-output">Download</button>
                        </div>
                        <label for="tool-output">Result</label>
                        <textarea id="tool-output" class="tool-textarea" readonly spellcheck="false"></textarea>
                    {% elseif tool.widget == 'percent-calculator' %}
                        <label for="percent-base">Base value</label>
                        <input id="percent-base" class="tool-input" type="number" step="any" placeholder="10000">
                        <label for="percent-rate">Percent (%)</label>
                        <input id="percent-rate" class="tool-input" type="number" step="any" placeholder="15">
                        <div class="tool-actions">
                            <button type="button" class="tool-btn primary" data-action="percent-calculate">Calculate</button>
                        </div>
                        <div class="result-grid three">
                            <div><span>Percent value</span><strong id="percent-value">-</strong></div>
                            <div><span>Added total</span><strong id="percent-added">-</strong></div>
                            <div><span>Discounted total</span><strong id="percent-discounted">-</strong></div>
                        </div>
                    {% elseif tool.widget == 'vat-calculator' %}
                        <label for="vat-amount">Amount</label>
                        <input id="vat-amount" class="tool-input" type="number" step="any" placeholder="100000">
                        <label for="vat-rate">VAT Rate (%)</label>
                        <input id="vat-rate" class="tool-input" type="number" step="any" value="10">
                        <div class="tool-actions">
                            <button type="button" class="tool-btn primary" data-action="vat-from-supply">Supply + VAT</button>
                            <button type="button" class="tool-btn" data-action="vat-from-total">Total includes VAT</button>
                        </div>
                        <div class="result-grid three">
                            <div><span>Supply</span><strong id="vat-supply">-</strong></div>
                            <div><span>VAT</span><strong id="vat-tax">-</strong></div>
                            <div><span>Total</span><strong id="vat-total">-</strong></div>
                        </div>
                    {% elseif tool.widget == 'd-day-calculator' %}
                        <label for="dday-date">Target date</label>
                        <input id="dday-date" class="tool-input" type="date">
                        <div class="tool-actions"><button type="button" class="tool-btn primary" data-action="dday-calculate">Calculate</button></div>
                        <div class="result-grid">
                            <div><span>D-Day</span><strong id="dday-result">-</strong></div>
                            <div><span>Target</span><strong id="dday-target">-</strong></div>
                        </div>
                    {% elseif tool.widget == 'age-calculator' %}
                        <label for="birth-date">Birth date</label>
                        <input id="birth-date" class="tool-input" type="date">
                        <label for="age-base-date">Base date</label>
                        <input id="age-base-date" class="tool-input" type="date">
                        <div class="tool-actions"><button type="button" class="tool-btn primary" data-action="age-calculate">Calculate</button></div>
                        <div class="result-grid three">
                            <div><span>Age</span><strong id="age-years">-</strong></div>
                            <div><span>Months lived</span><strong id="age-months">-</strong></div>
                            <div><span>Days lived</span><strong id="age-days">-</strong></div>
                        </div>
                    {% else %}
                        <label for="tool-input">Input</label>
                        <textarea id="tool-input" class="tool-textarea" spellcheck="false" placeholder="{{ tool.name }} 기능은 단계적으로 고도화됩니다."></textarea>
                        <div class="tool-actions">
                            <button type="button" class="tool-btn primary" data-action="generic-copy">Prepare Input</button>
                            <button type="button" class="tool-btn" data-copy="#tool-output">Copy</button>
                            <button type="button" class="tool-btn" data-download="#tool-output">Download</button>
                        </div>
                        <label for="tool-output">Result</label>
                        <textarea id="tool-output" class="tool-textarea" readonly>{{ tool.name }} is registered in WY Tools. The interactive engine for this tool will be added in a later step.</textarea>
                    {% endif %}
                    <p class="tool-status" id="tool-status" aria-live="polite"></p>
                </div>

                {% include 'tools/partials/_ad_slot.html.twig' with { position: 'middle' } %}

                <section class="content-block">
                    <h2>사용법</h2>
                    <ol>{% for step in tool.how_to_use %}<li>{{ step }}</li>{% endfor %}</ol>
                </section>

                <section class="content-block">
                    <h2>예제</h2>
                    {% for example in tool.examples %}
                        <article class="example-card">
                            <h3>{{ example.title }}</h3>
                            <p><strong>Input:</strong> {{ example.input }}</p>
                            <p><strong>Output:</strong> {{ example.output }}</p>
                        </article>
                    {% endfor %}
                </section>

                <section class="content-block">
                    <h2>FAQ</h2>
                    <div class="faq-list">
                        {% for faq in tool.faqs %}
                            <details><summary>{{ faq.q }}</summary><p>{{ faq.a }}</p></details>
                        {% endfor %}
                    </div>
                </section>

                {% include 'tools/partials/_ad_slot.html.twig' with { position: 'after-faq' } %}

                <section class="content-block">
                    <h2>관련 도구</h2>
                    <div class="wy-tool-grid small">
                        {% for item in related_tools %}
                            {% include 'tools/partials/_tool_card.html.twig' with { item: item } %}
                        {% endfor %}
                    </div>
                </section>
            </main>

            <aside class="tool-sidebar">
                <div class="help-box">
                    <h2>도구 정보</h2>
                    <p>{{ tool.summary }}</p>
                    <a href="/tools/category/{{ tool.category }}">{{ category.name|default(tool.category) }} Tools</a>
                </div>
                <div class="help-box">
                    <h2>최근 사용</h2>
                    <div class="compact-list" data-recent-tools></div>
                </div>
            </aside>
        </div>
    </section>

    {% include 'tools/partials/_ad_slot.html.twig' with { position: 'footer' } %}
</div>
{% endblock %}

{% block scripts %}
    {% if tool.widget == 'qr-code' %}
        <script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
    {% endif %}
    <script src="/assets/js/tools.js"></script>
{% endblock %}

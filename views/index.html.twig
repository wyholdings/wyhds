{% extends 'layout/base.html.twig' %}
{% set isMain = true %}

{% block body %}
<main class="scholar-main">
    <section id="mainvisual" class="scholar-hero">
        <div class="scholar-shell hero-grid">
            <div class="hero-copy">
                <p class="eyebrow">학회·협회·컨퍼런스 홈페이지 전문 구축</p>
                <h2>학회 운영에 필요한 모든 기능을 한번에</h2>
                <p class="lead">참가등록 · 초록접수 · 결제 · 관리자 통합 구축</p>
                <p class="desc">학술행사 운영에 필요한 기능을 한번에 제공합니다.<br>다수의 학회 및 국제컨퍼런스 구축 경험을 바탕으로 운영자가 편하게 관리할 수 있는 맞춤형 시스템을 구축합니다.</p>
                <div class="hero-actions">
                    <a class="btn primary" href="/contact">빠른 견적 문의</a>
                    <a class="btn secondary" href="/portfolio">실제 구축 사례 보기</a>
                </div>
            </div>

            <div class="hero-device" aria-hidden="true">
                {% set heroMockups = [
                    {'image':'/images/visual_item01.png','caption':'참가등록 · 초록접수 · 결제 통합 구축'},
                    {'image':'/images/visual_item02.png','caption':'X배너 · 포스터 · 프로그램북 디자인 지원'},
                    {'image':'/images/visual_item03.png','caption':'초록집 · 뉴스레터 · 자료집 eBook 제작'}
                ] %}
                <div class="swiper hero-mockup-swiper hero-image">
                    <div class="swiper-wrapper">
                        {% for mockup in heroMockups %}
                            <div class="swiper-slide">
                                <img src="{{ mockup.image }}" alt="">
                                <p class="hero-mockup-caption">{{ mockup.caption }}</p>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                if (!window.Swiper) {
                    return;
                }

                new Swiper('.hero-mockup-swiper', {
                    loop: true,
                    speed: 700,
                    effect: 'fade',
                    fadeEffect: {
                        crossFade: true
                    },
                    autoplay: {
                        delay: 3200,
                        disableOnInteraction: false
                    }
                });
            });
        </script>
    </section>

    <section class="strength-band">
        <div class="scholar-shell strength-grid">
            <article><span class="line-icon"><i data-lucide="graduation-cap"></i></span><strong>학회 특화 구축</strong><p>학회·협회·컨퍼런스 구축 경험이 축적된 전문 기업</p></article>
            <article><span class="line-icon"><i data-lucide="monitor-cog"></i></span><strong>통합 운영 시스템</strong><p>등록, 초록접수, 결제, 메일발송, 통계까지 통합 제공</p></article>
            <article><span class="line-icon"><i data-lucide="workflow"></i></span><strong>관리자 업무 자동화</strong><p>관리 편의 기능으로 반복 업무와 운영 부담 축소</p></article>
            <article><span class="line-icon"><i data-lucide="shield-check"></i></span><strong>유지보수 지원</strong><p>오픈 후 안정적인 운영과 지속적인 기술 지원</p></article>
        </div>
    </section>

    <section id="portfolio" class="case-section">
        <div class="section-title">
            <span>PORTFOLIO</span>
            <h3>실제 구축 사례</h3>
            <p>다양한 학회와 국제컨퍼런스의 성공적인 홈페이지 구축 경험을 확인하세요.</p>
        </div>
        <div class="scholar-shell case-slider-wrap">
            {% set cases = [
                {'title':'대한방사선방어학회','image':'/images/work02.png','desc':'학회 홈페이지 및 춘계·추계 학술대회 운영','items':['참가등록 및 결제 시스템','초록접수 및 심사 관리','프로그램 및 세션 관리','총회·행사 운영 지원']},
                {'title':'2025 개발협력주간','image':'/images/work04.png','desc':'국제컨퍼런스 홈페이지 구축 및 운영','items':['다국어 지원(국/영)','초록접수 및 발표자료 관리','등록 및 결제 시스템','프로그램 및 세션 관리']},
                {'title':'시온텍','image':'/images/work01.png','desc':'학회 홈페이지 리뉴얼 및 시스템 구축','items':['회원관리 시스템','학술지 및 논문 관리','학술대회 안내 및 등록','공지사항 및 자료실']},
                {'title':'글로벌평생학습 리더십 컨퍼런스','image':'/images/work05.png','desc':'국제행사 홈페이지 및 등록 시스템 운영','items':['행사 안내 페이지','참가등록 관리','메일 발송 및 공지','운영 통계 관리']},
                {'title':'사기방지 국제 컨퍼런스','image':'/images/work06.png','desc':'컨퍼런스 홈페이지 및 신청 시스템 구축','items':['다국어 행사 안내','등록 신청 시스템','관리자 승인 기능','참가자 데이터 관리']},
                {'title':'온자박푸드몰','image':'/images/work03.png','desc':'브랜드 쇼핑몰 및 회사소개 페이지 구축','items':['상품 소개 페이지','주문 문의 연동','반응형 웹 구축','관리자 콘텐츠 관리']}
            ] %}
            <div class="swiper case-swiper">
                <div class="swiper-wrapper">
                    {% for item in cases %}
                        <div class="swiper-slide">
                            <article class="case-card">
                                <div class="case-thumb"><img src="{{ item.image }}" alt="{{ item.title }}"><span>{{ loop.index < 10 ? '0' ~ loop.index : loop.index }}</span></div>
                                <div class="case-body">
                                    <h4>{{ item.title }}</h4>
                                    <p>{{ item.desc }}</p>
                                    <ul>
                                        {% for bullet in item.items %}
                                            <li>{{ bullet }}</li>
                                        {% endfor %}
                                    </ul>
                                    <a href="/portfolio">자세히 보기</a>
                                </div>
                            </article>
                        </div>
                    {% endfor %}
                </div>
                <div class="case-control">
                    <button type="button" class="case-prev" aria-label="이전 사례"><i data-lucide="chevron-left"></i></button>
                    <div class="case-pagination"></div>
                    <button type="button" class="case-next" aria-label="다음 사례"><i data-lucide="chevron-right"></i></button>
                </div>
            </div>
        </div>
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                if (!window.Swiper) {
                    return;
                }

                new Swiper('.case-swiper', {
                    loop: true,
                    speed: 700,
                    spaceBetween: 24,
                    slidesPerView: 3,
                    autoplay: {
                        delay: 3500,
                        disableOnInteraction: false
                    },
                    pagination: {
                        el: '.case-pagination',
                        clickable: true
                    },
                    navigation: {
                        prevEl: '.case-prev',
                        nextEl: '.case-next'
                    },
                    breakpoints: {
                        0: {
                            slidesPerView: 1,
                            spaceBetween: 16
                        },
                        768: {
                            slidesPerView: 2,
                            spaceBetween: 20
                        },
                        1180: {
                            slidesPerView: 3,
                            spaceBetween: 24
                        }
                    }
                });
            });
        </script>
    </section>

    <section id="features" class="feature-section">
        <div class="section-title">
            <span>FEATURES</span>
            <h3>학회 운영에 필요한 모든 기능</h3>
            <p>학술행사 운영에 필요한 기능을 하나의 시스템으로 제공합니다.</p>
        </div>
        <div class="scholar-shell feature-grid">
            {% set features = [
                ['user-check','참가등록 시스템','온라인 참가등록 및 현장등록 관리'],
                ['file-text','초록접수 시스템','초록 제출, 심사, 발표 관리 시스템'],
                ['credit-card','결제 시스템','카드결제, 가상계좌 실시간 결제 연동'],
                ['users-round','관리자 기능','참가자, 초록, 결제 현황 통계 및 엑셀 다운로드'],
                ['mail','메일 발송','대량 메일 발송 및 자동 알림 기능'],
                ['smartphone','반응형 홈페이지','PC, 모바일, 태블릿 완벽 지원'],
                ['palette','제작물 디자인','초대장, 배너, 프로그램북 등 행사 제작물 디자인'],
                ['book-open','EBOOK','자료집, 초록집, 논문집 EBOOK 제작 및 열람 지원']
            ] %}
            {% for feature in features %}
                <article><span><i data-lucide="{{ feature[0] }}"></i></span><strong>{{ feature[1] }}</strong><p>{{ feature[2] }}</p></article>
            {% endfor %}
        </div>
    </section>

    <section id="process" class="process-section">
        <div class="scholar-shell process-grid">
            <div class="process-copy">
                <span>PROCESS</span>
                <h3>체계적인 제작 프로세스</h3>
                <p>상담부터 오픈까지 체계적인 프로세스로 성공적인 홈페이지를 구축합니다.</p>
                {# <a href="/contact">제작 프로세스 자세히 보기</a> #}
            </div>
            <ol class="process-list">
                <li><span><i data-lucide="clipboard-check"></i></span><b>01</b><strong>상담 및 요구사항 확인</strong><p>학회 및 행사 특성, 필요한 기능 확인</p></li>
                <li><span><i data-lucide="file-search"></i></span><b>02</b><strong>기획 및 견적 안내</strong><p>페이지 구성, 기능 범위, 일정 및 견적 안내</p></li>
                <li><span><i data-lucide="settings"></i></span><b>03</b><strong>디자인 및 개발</strong><p>반응형 디자인 및 시스템 개발 진행</p></li>
                <li><span><i data-lucide="badge-check"></i></span><b>04</b><strong>테스트 및 오픈</strong><p>테스트 후 수정, 최종 검수 및 오픈</p></li>
                <li><span><i data-lucide="life-buoy"></i></span><b>05</b><strong>운영 및 유지보수</strong><p>안정적인 운영과 지속적인 지원</p></li>
            </ol>
        </div>
    </section>

    <section id="contact" class="scholar-contact">
        <div class="scholar-shell contact-grid">
            <div class="contact-copy">
                <h3>학회 홈페이지 제작이<br>필요하신가요?</h3>
                <p>기관 정보와 예산, 필요한 내용을 남겨주시면 빠르게 견적을 안내해 드리겠습니다.</p>
            </div>
            <form id="contactForm" class="quick-form" method="post" action="/contact/submit" novalidate>
                <input type="hidden" name="contact_token" value="{{ contact_form_token|default(contact_token|default('')) }}">
                <input type="hidden" name="contact_method" value="" tabindex="-1" autocomplete="off" class="contact-honeypot" aria-hidden="true">
                <input type="text" name="company" placeholder="기관명/학회명/회사명" required>
                <input type="text" name="name" placeholder="담당자명">
                <input type="tel" name="phone" placeholder="연락처">
                <input type="email" name="email" placeholder="이메일">
                <select name="money" required>
                    <option value="">예산 선택</option>
                    <option value="300">300만원 이하</option>
                    <option value="500">300만원 - 500만원</option>
                    <option value="1000">500만원 - 1,000만원</option>
                    <option value="2000">1,000만원 - 2,000만원</option>
                    <option value="3000">2,000만원 이상</option>
                </select>
                <input type="text" name="due_date" placeholder="희망 완료일자">
                <textarea name="message" placeholder="문의 내용을 간단히 입력해주세요."></textarea>
                <button type="submit">무료 견적 문의하기 <i data-lucide="send"></i></button>
                <p id="formMessage" class="form-message" aria-live="polite"></p>
            </form>
        </div>
    </section>
    <script src="/assets/js/contact.js"></script>
</main>
{% endblock %}
